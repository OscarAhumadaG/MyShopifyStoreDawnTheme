{% comment %}
  Renders share button — copies URL to clipboard immediately on click.
  Accepts:
  - block: {Object} block information
  - share_link: {String} URL to copy
  - icon_size: {Number} icon size in px (optional, default 14)
{% endcomment %}
{%- assign resolved_icon_size = icon_size | default: 14 -%}
{%- assign btn_id = 'share-btn-' | append: section.id -%}
{%- assign toast_id = 'share-toast-' | append: section.id -%}
<div class="share-button-wrapper quick-add-hidden" style="position:relative;">
  <button
    id="{{ btn_id }}"
    class="share-copy-btn"
    type="button"
    aria-label="Share"
    data-url="{{ share_link }}"
  >
    <span class="svg-wrapper" style="width:{{ resolved_icon_size }}px;height:{{ resolved_icon_size }}px;display:inline-flex;align-items:center;justify-content:center;">
      {{ 'icon-share.svg' | inline_asset_content }}
    </span>
  </button>
  <span id="{{ toast_id }}" class="share-toast" aria-live="polite"></span>
</div>
<style>
  .share-copy-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 0;
    padding: 0;
    cursor: pointer;
    box-shadow: none;
    line-height: 1;
  }
  .share-copy-btn .svg-wrapper svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .share-toast {
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: #1a1a1a;
    color: #fff;
    font-size: 11px;
    white-space: nowrap;
    padding: 4px 10px;
    border-radius: 6px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease;
    z-index: 100;
  }
  .share-toast.visible {
    opacity: 1;
  }
</style>
<script>
(function() {
  var btn   = document.getElementById('{{ btn_id }}');
  var toast = document.getElementById('{{ toast_id }}');
  if (!btn) return;
  btn.addEventListener('click', function() {
    var url = btn.getAttribute('data-url');
    function showToast(msg) {
      toast.textContent = msg;
      toast.classList.add('visible');
      setTimeout(function() { toast.classList.remove('visible'); }, 2000);
    }
    if (navigator.share) {
      navigator.share({ url: url }).catch(function() {});
    } else if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(url).then(function() {
        showToast('{{ 'general.share.copy_to_clipboard' | t | escape }}');
      }).catch(function() {
        fallbackCopy(url);
      });
    } else {
      fallbackCopy(url);
    }
    function fallbackCopy(text) {
      var ta = document.createElement('textarea');
      ta.value = text;
      ta.style.cssText = 'position:fixed;opacity:0;top:0;left:0;';
      document.body.appendChild(ta);
      ta.focus();
      ta.select();
      try {
        document.execCommand('copy');
        showToast('{{ 'general.share.copy_to_clipboard' | t | escape }}');
      } catch(e) {}
      document.body.removeChild(ta);
    }
  });
})();
</script>