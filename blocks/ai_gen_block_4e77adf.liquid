{% doc %}
  @prompt
    QUIERO UNA SECCION QUE HORIZONTALMENTE ESTE DIVIDA EN DOS LA PARTE DE LA IZQUIERDA QUE SEA PARA UNA IMAGEN QUE CONECTA A WHATSAPP A UN NUMERO EN PARTICULAR Y LA SEGUNDA LA DE LA DERECHA ES PARA UNA IMAGEN QUE CONECTA CON UN CORREO ELECTRONICO, QUIERO QUE PUEDA EDITAR LA POSICION EL TAMAÑO, LOS BORDES ETC  Y ADEMAS QUE ME PERMITA COLOCAR UNA IMAEGN ABAJO LARGA DOND EPUEDA COLOCAR MIS HORARIOS DE ATENCION  QUIERO ADEMAS QUE ME PEMIRTA EDITAR COMO SE AJUSTA LA IMAGEN Y TAMBIEN EL TAMAÑO DE LOS CONTENEDORES DE LAS IMAGENES Y AL ACHO QUE OCUPA TODO EN LA PAGINA TANTO EN MOBILE COMO EN DESKTOP, NO SE ESTAN VIENDO LAS IMAGENES ADEMAS QUIERO QUE ES MOVIL SE VEA IGUAL DOS COLUMNAS UNA PARA WHATSAPP Y UNA PARA CORREO Y ABAJO LA DEL LOS HORARIOS QUIERO ADEMAS QUE PUEDA MANIPULAR EL ANCHO TOTAL DE TODO PARA QUE QUEDE ALINEADO CON LOS OTROS ITEMS DENTRO DEN LA PAGINA, POR OTRO LADO EL LINK PARA MANDAR EL MAIL EN LA PASADA SECCION NO CNECTABA CON NINGUN CORREO, TAMBIEN AGREGA BORDES Y GROSOR Y COLOR DE LOS MISMOS PARA DIFERENCIAR
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-section-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
    box-sizing: border-box;
  }

  .ai-contact-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    width: 100%;
  }

  .ai-contact-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.gap_between_items }}px;
    margin-bottom: {{ block.settings.gap_between_items }}px;
  }

  .ai-contact-item-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.top_items_height }}px;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    display: block;
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    box-sizing: border-box;
  }

  .ai-contact-item-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_fit }};
    display: block;
  }

  .ai-contact-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-contact-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-contact-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-contact-schedule-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.schedule_height }}px;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    box-sizing: border-box;
  }

  .ai-contact-schedule-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.schedule_image_fit }};
    display: block;
  }

  @media screen and (max-width: 749px) {
    .ai-contact-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px {{ block.settings.section_padding_horizontal_mobile }}px {{ block.settings.section_padding_bottom_mobile }}px;
    }

    .ai-contact-container-{{ ai_gen_id }} {
      max-width: {{ block.settings.container_width_mobile }}px;
    }

    .ai-contact-grid-{{ ai_gen_id }} {
      gap: {{ block.settings.gap_between_items_mobile }}px;
      margin-bottom: {{ block.settings.gap_between_items_mobile }}px;
    }

    .ai-contact-item-{{ ai_gen_id }} {
      height: {{ block.settings.top_items_height_mobile }}px;
    }

    .ai-contact-schedule-{{ ai_gen_id }} {
      height: {{ block.settings.schedule_height_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-contact-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-container-{{ ai_gen_id }}">
    <div class="ai-contact-grid-{{ ai_gen_id }}">
      <a
        href="https://wa.me/{{ block.settings.whatsapp_number }}"
        class="ai-contact-item-{{ ai_gen_id }}"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Contactar por WhatsApp"
      >
        {% if block.settings.whatsapp_image %}
          <img
            src="{{ block.settings.whatsapp_image | image_url: width: 1000 }}"
            alt="WhatsApp"
            loading="lazy"
            width="{{ block.settings.whatsapp_image.width }}"
            height="{{ block.settings.whatsapp_image.height }}"
          >
        {% else %}
          <div class="ai-contact-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-contact-empty-state-{{ ai_gen_id }}">
              Agregar imagen de WhatsApp
            </div>
          </div>
        {% endif %}
      </a>

      <a
        href="mailto:{{ block.settings.email_address }}"
        class="ai-contact-item-{{ ai_gen_id }}"
        aria-label="Enviar correo electrónico"
      >
        {% if block.settings.email_image %}
          <img
            src="{{ block.settings.email_image | image_url: width: 1000 }}"
            alt="Email"
            loading="lazy"
            width="{{ block.settings.email_image.width }}"
            height="{{ block.settings.email_image.height }}"
          >
        {% else %}
          <div class="ai-contact-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-contact-empty-state-{{ ai_gen_id }}">
              Agregar imagen de Email
            </div>
          </div>
        {% endif %}
      </a>
    </div>

    <div class="ai-contact-schedule-{{ ai_gen_id }}">
      {% if block.settings.schedule_image %}
        <img
          src="{{ block.settings.schedule_image | image_url: width: 2000 }}"
          alt="Horarios de atención"
          loading="lazy"
          width="{{ block.settings.schedule_image.width }}"
          height="{{ block.settings.schedule_image.height }}"
        >
      {% else %}
        <div class="ai-contact-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-contact-empty-state-{{ ai_gen_id }}">
            Agregar imagen de horarios
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
