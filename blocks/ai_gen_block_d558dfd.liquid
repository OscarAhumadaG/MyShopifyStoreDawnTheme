{% doc %}
  @prompt
    Genera una sección de video a pantalla completa para Shopify 2.0 que reproduzca un MP4 desde una URL de Shopify (HTTPS) y permita controlar el diseño: opción de autoplay, loop (repetición) y muted (requerido para autoplay móvil); posibilidad de ocultar los controles para que solo se vea el video; ajuste de object-fit con valores cover, contain y fill (por defecto cover para evitar franjas negras y ocupar toda la pantalla); el video debe mostrarse en full-screen (usar width:100vw y height:100vh) y playsinline para móviles; incluir ajustes de fondo del contenedor, borde (color y ancho) y sombra (editable) con opción por defecto sin borde ni sombra; el editor debe ofrecer campos: video_url (URL MP4), autoplay, loop, muted, show_controls, object_fit, background, border_color, border_width, shadow; implementar CSS/JS mínimo sin dependencias externas y carga diferida, garantizando que al activar show_controls=false el video no muestre controles y se vea limpio ocupando toda la pantalla sin franjas superiores o inferiores.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-fullscreen-video-{{ ai_gen_id }} {
    position: relative;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    {% if block.settings.border_width > 0 %}
      border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
      box-sizing: border-box;
    {% endif %}
    {% if block.settings.shadow_opacity > 0 %}
      box-shadow: 0 4px 20px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
    {% endif %}
  }

  .ai-fullscreen-video-{{ ai_gen_id }}__video {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.object_fit }};
    display: block;
  }

  .ai-fullscreen-video-{{ ai_gen_id }}__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    position: relative;
  }

  .ai-fullscreen-video-{{ ai_gen_id }}__placeholder svg {
    width: 100px;
    height: 100px;
    opacity: 0.3;
  }

  .ai-fullscreen-video-{{ ai_gen_id }}__empty-state {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 24px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }
{% endstyle %}

<fullscreen-video-{{ ai_gen_id }}
  class="ai-fullscreen-video-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.video_url != blank %}
    <video
      class="ai-fullscreen-video-{{ ai_gen_id }}__video"
      {% if block.settings.autoplay %}autoplay{% endif %}
      {% if block.settings.loop %}loop{% endif %}
      {% if block.settings.muted %}muted{% endif %}
      {% unless block.settings.show_controls %}controls="false"{% endunless %}
      {% if block.settings.show_controls %}controls{% endif %}
      playsinline
      preload="metadata"
      aria-label="Video de pantalla completa"
    >
      <source src="{{ block.settings.video_url }}" type="video/mp4">
      Tu navegador no soporta la reproducción de video.
    </video>
  {% else %}
    <div class="ai-fullscreen-video-{{ ai_gen_id }}__placeholder">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="5 3 19 12 5 21 5 3"></polygon>
      </svg>
      <div class="ai-fullscreen-video-{{ ai_gen_id }}__empty-state">
        Agrega una URL de video MP4 para comenzar
      </div>
    </div>
  {% endif %}
</fullscreen-video-{{ ai_gen_id }}>

<script>
  (function() {
    class FullscreenVideo{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.video = this.querySelector('video');
      }

      connectedCallback() {
        if (this.video) {
          this.setupVideo();
        }
      }

      setupVideo() {
        this.video.addEventListener('loadedmetadata', () => {
          if (this.video.readyState >= 2) {
            this.video.play().catch(() => {});
          }
        });

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              this.video.play().catch(() => {});
            } else {
              this.video.pause();
            }
          });
        }, { threshold: 0.5 });

        observer.observe(this);
      }
    }

    customElements.define('fullscreen-video-{{ ai_gen_id }}', FullscreenVideo{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Video pantalla completa",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "URL del video MP4"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Reproducción automática",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Repetir video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "muted",
      "label": "Silenciar video",
      "default": true,
      "info": "Requerido para autoplay en móviles"
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Mostrar controles",
      "default": false
    },
    {
      "type": "select",
      "id": "object_fit",
      "label": "Ajuste del video",
      "options": [
        {
          "value": "cover",
          "label": "Cubrir (sin franjas)"
        },
        {
          "value": "contain",
          "label": "Contener (ajustar)"
        },
        {
          "value": "fill",
          "label": "Rellenar (estirar)"
        }
      ],
      "default": "cover",
      "info": "Cover elimina franjas negras ocupando toda la pantalla"
    },
    {
      "type": "header",
      "content": "Estilo"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Color del borde",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Ancho del borde",
      "default": 0
    },
    {
      "type": "range",
      "id": "shadow_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Opacidad de sombra",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Video pantalla completa"
    }
  ]
}
{% endschema %}
