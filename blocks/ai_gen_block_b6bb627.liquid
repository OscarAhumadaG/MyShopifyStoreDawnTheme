    },
    {
      "type": "color",
      "id": "input_background_color",
      "label": "Fondo de campo",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "input_text_color",
      "label": "Texto de campo",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "input_border_color",
      "label": "Borde de campo",
      "default": "#cccccc"
    },
    {
      "type": "color",
      "id": "input_focus_color",
      "label": "Enfoque de campo",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "input_border_radius",
      "min": 0,
      "max": 20,
      "step": 2,
