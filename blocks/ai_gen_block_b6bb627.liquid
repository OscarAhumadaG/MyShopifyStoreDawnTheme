      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Radio de borde",
      "default": 8
    },
    {
      "type": "header",
      "content": "Colores"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fondo",
      "default": "#f3f3f3"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Título",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Texto",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "label_color",
