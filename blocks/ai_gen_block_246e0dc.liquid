{% schema %}
{
  "name": "Productos destacados",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "inline_richtext",
      "id": "section_title",
      "label": "Título de la sección",
      "default": "Productos destacados"
    },
    {
      "type": "header",
      "content": "Productos"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Producto 1"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Producto 2"
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "Producto 3"
    },
    {
      "type": "product",
      "id": "product_4",
      "label": "Producto 4"
    },
    {
      "type": "product",
      "id": "product_5",
      "label": "Producto 5"
    },
    {
      "type": "product",
      "id": "product_6",
      "label": "Producto 6"
    },
    {
      "type": "product",
      "id": "product_7",
      "label": "Producto 7"
    },
    {
      "type": "product",
      "id": "product_8",
      "label": "Producto 8"
    },
    {
      "type": "product",
      "id": "product_9",
      "label": "Producto 9"
    },
    {
      "type": "product",
      "id": "product_10",
      "label": "Producto 10"
    },
    {
      "type": "header",
      "content": "Estilo del título"
    },
    {
      "type": "font_picker",
      "id": "title_font",
      "label": "Fuente del título",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Tamaño del título",
      "default": 32
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color del título",
      "default": "#121212"
    },
    {
      "type": "select",
      "id": "title_alignment",
      "label": "Alineación del título",
      "options": [
        {
          "value": "left",
          "label": "Izquierda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Derecha"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "title_spacing",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Espaciado inferior del título",
      "default": 30
    },
    {
      "type": "header",
      "content": "Diseño de productos"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 1000,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "label": "Ancho del contenedor",
      "default": 1200
    },
    {
      "type": "range",
      "id": "product_width",
      "min": 150,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Ancho de cada producto",
      "default": 250
    },
    {
      "type": "range",
      "id": "product_spacing",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Espaciado entre productos",
      "default": 20
    },
    {
      "type": "range",
      "id": "product_padding",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Relleno interno del producto",
      "default": 15
    },
    {
      "type": "color",
      "id": "product_bg_color",
      "label": "Color de fondo del producto",
      "default": "#ffffff"
    },
    {
