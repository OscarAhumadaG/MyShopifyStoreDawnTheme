        {
          "value": "left_to_right",
          "label": "Izquierda a derecha"
        },
        {
          "value": "right_to_left",
          "label": "Derecha a izquierda"
        }
      ],
      "default": "right_to_left",
      "info": "Solo aplica para deslizamiento horizontal"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Reproducción automática",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Velocidad de cambio",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    }
  ],
  "presets": [
    {
      "name": "Barra de anuncios"
    }
  ]
}
{% endschema %}