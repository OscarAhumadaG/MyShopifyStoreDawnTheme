    {
      "type": "text",
      "id": "announcement_1",
      "label": "Anuncio 1",
      "default": "🚚 Envío gratis en pedidos superiores a $50.000"
    },
    {
      "type": "text",
      "id": "announcement_2",
      "label": "Anuncio 2",
      "default": "🎉 20% de descuento en toda la tienda"
    },
    {
      "type": "text",
      "id": "announcement_3",
      "label": "Anuncio 3"
    },
    {
      "type": "text",
      "id": "announcement_4",
      "label": "Anuncio 4"
    },
    {
      "type": "text",
      "id": "announcement_5",
      "label": "Anuncio 5"
    },
