{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-team-intro-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-team-intro-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: {{ block.settings.gap }}px;
  }

  .ai-team-intro-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    flex: 0 0 {{ block.settings.image_width }}%;
    width: {{ block.settings.image_width }}%;
  }

  .ai-team-intro-image-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    border-radius: {{ block.settings.image_border_radius }}px;
    border: {{ block.settings.image_border_width }}px {{ block.settings.image_border_style }} {{ block.settings.image_border_color }};
    box-shadow: {{ block.settings.shadow_horizontal }}px {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px {{ block.settings.shadow_spread }}px {{ block.settings.shadow_color }};
    background-color: {{ block.settings.frame_background }};
    padding: {{ block.settings.frame_padding }}px;
  }

  .ai-team-intro-image-inner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    border-radius: {{ block.settings.inner_border_radius }}px;
  }

  .ai-team-intro-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_fit }};
    object-position: {{ block.settings.image_position }};
    opacity: 0;
    transition: opacity {{ block.settings.transition_duration }}s ease-in-out;
  }

  .ai-team-intro-image-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-team-intro-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-team-intro-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-team-intro-content-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-team-intro-content-image-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: {{ block.settings.content_image_spacing }}px;
    border-radius: {{ block.settings.content_image_border_radius }}px;
  }

  .ai-team-intro-content-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.content_image_border_radius }}px;
  }

  .ai-team-intro-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.text_spacing }}px;
  }

  .ai-team-intro-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-team-intro-text-{{ ai_gen_id }} p {
    margin: 0 0 16px;
  }

  .ai-team-intro-text-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-team-intro-container-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.mobile_layout }};
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-team-intro-image-wrapper-{{ ai_gen_id }} {
      flex: 0 0 auto;
      width: {{ block.settings.mobile_image_width }}%;
    }

    .ai-team-intro-image-container-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_frame_padding }}px;
    }

    .ai-team-intro-image-inner-{{ ai_gen_id }} {
      padding-bottom: {{ block.settings.mobile_image_aspect_ratio }}%;
    }

    .ai-team-intro-content-image-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.mobile_content_image_spacing }}px;
    }

    .ai-team-intro-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_heading_size }}px;
    }

    .ai-team-intro-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_text_size }}px;
    }

    .ai-team-intro-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_padding_top }}px 20px {{ block.settings.mobile_padding_bottom }}px;
    }
  }
{% endstyle %}

<team-intro-{{ ai_gen_id }} class="ai-team-intro-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-team-intro-container-{{ ai_gen_id }}">
    <div class="ai-team-intro-image-wrapper-{{ ai_gen_id }}">
      <div class="ai-team-intro-image-container-{{ ai_gen_id }}">
        <div class="ai-team-intro-image-inner-{{ ai_gen_id }}">
          {% if block.settings.image_1 or block.settings.image_2 %}
            {% if block.settings.image_1 %}
              <img
                src="{{ block.settings.image_1 | image_url: width: 800 }}"
                alt="{{ block.settings.image_1.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.image_1.width }}"
                height="{{ block.settings.image_1.height }}"
                class="ai-team-intro-image-{{ ai_gen_id }} active"
                data-image="1"
              >
            {% endif %}
            {% if block.settings.image_2 %}
              <img
                src="{{ block.settings.image_2 | image_url: width: 800 }}"
                alt="{{ block.settings.image_2.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.image_2.width }}"
                height="{{ block.settings.image_2.height }}"
                class="ai-team-intro-image-{{ ai_gen_id }}"
                data-image="2"
              >
            {% endif %}
          {% else %}
            <div class="ai-team-intro-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="ai-team-intro-content-{{ ai_gen_id }}">
      {% if block.settings.content_image %}
        <div class="ai-team-intro-content-image-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.content_image | image_url: width: 1200 }}"
            alt="{{ block.settings.content_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.content_image.width }}"
            height="{{ block.settings.content_image.height }}"
          >
        </div>
      {% endif %}
      {% if block.settings.heading != blank %}
        <h2 class="ai-team-intro-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.text != blank %}
        <div class="ai-team-intro-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}
    </div>
  </div>
</team-intro-{{ ai_gen_id }}>

<script>
  (function() {
    class TeamIntro{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.images = this.querySelectorAll('.ai-team-intro-image-{{ ai_gen_id }}');
        this.currentIndex = 0;
        this.interval = {{ block.settings.interval | times: 1000 }};
        this.autoRotate = {{ block.settings.auto_rotate }};
        this.intervalId = null;
      }

      connectedCallback() {
        if (this.autoRotate && this.images.length > 1) {
          this.startRotation();
        }
      }

      disconnectedCallback() {
        this.stopRotation();
      }

      startRotation() {
        this.intervalId = setInterval(() => {
          this.switchImage();
        }, this.interval);
      }

      stopRotation() {
        if (this.intervalId) {
          clearInterval(this.intervalId);
          this.intervalId = null;
        }
      }

      switchImage() {
        this.images[this.currentIndex].classList.remove('active');
        this.currentIndex = (this.currentIndex + 1) % this.images.length;
        this.images[this.currentIndex].classList.add('active');
      }
    }

    customElements.define('team-intro-{{ ai_gen_id }}', TeamIntro{{ ai_gen_id }});
  })();
</script>

