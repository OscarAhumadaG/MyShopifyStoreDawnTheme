{% assign ai_gen_id = block.id | replace: '_', '' | replace: '-', '' | downcase %}
{% assign icon_opacity = block.settings.info_icon_opacity | divided_by: 100.0 %}
{% assign desc_opacity = block.settings.description_bg_opacity | divided_by: 100.0 %}

{% assign ns_cfg  = block.settings.meta_ns  | default:'custom' %}
{% assign key_cfg = block.settings.meta_key | default:'feature_facts' %}
{% assign mf = product.metafields[ns_cfg][key_cfg] %}

{% if mf and mf.value and mf.type contains 'list.' %}
  {% assign feature_items = mf.value %}
{% endif %}

{% style %}
  .ai-media-strip-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    overflow: hidden;
    position: relative;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-media-strip-header-{{ ai_gen_id }} {
    margin-left: {{ block.settings.start_spacing }}px;
    margin-right: {{ block.settings.item_spacing }}px;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-media-strip-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    line-height: 1.2;
    margin: 0 0 {{ block.settings.subtitle_spacing }}px 0;
    color: {{ block.settings.title_color }};
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
  }

  .ai-media-strip-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_font_size }}px;
    font-weight: {{ block.settings.subtitle_font_weight }};
    line-height: 1.6;
    margin: 0;
    color: {{ block.settings.subtitle_color }};
    letter-spacing: {{ block.settings.subtitle_letter_spacing }}px;
    max-width: 600px;
  }

  .ai-media-strip-wrapper-{{ ai_gen_id }} {
    margin-left: {{ block.settings.start_spacing }}px;
    margin-right: {{ block.settings.item_spacing }}px;
  }

  .ai-media-strip-container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.item_spacing }}px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-snap-type: x mandatory;
  }

  .ai-media-strip-container-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-media-strip-item-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: {{ block.settings.item_width_desktop }}px;
    position: relative;
    scroll-snap-align: start;
    scroll-snap-stop: normal;
  }

  .ai-media-strip-media-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.item_height_desktop }}px;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    background-color: #f4f4f4;
    cursor: pointer;
    display: flex;
    flex-direction: column;
  }

  /* ::after pseudo-element overlay */
  .ai-media-strip-media-wrapper-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 120px;
    background: linear-gradient(to top, {{ block.settings.description_bg_color | color_modify: 'alpha', desc_opacity }}, transparent);
    z-index: 2;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .ai-media-strip-media-wrapper-{{ ai_gen_id }}.active::after {
    opacity: 1;
  }

  .ai-media-strip-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    position: absolute;
    top: 0;
    left: 0;
    z-index: 1;
  }

  .ai-media-strip-media-wrapper-{{ ai_gen_id }}.active .ai-media-strip-image-{{ ai_gen_id }} {
    transform: scale(1.02);
  }

  .ai-media-strip-video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 1;
  }

  .ai-media-strip-feature-content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 3;
    padding: {{ block.settings.feature_title_offset }}px {{ block.settings.feature_title_offset }}px {{ block.settings.description_bg_padding }}px;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    max-height: none;
    overflow: visible;
    transform: translateY(0);
  }

  .ai-media-strip-feature-title-{{ ai_gen_id }} {
    background-color: transparent;
    color: {{ block.settings.feature_title_color }};
    padding: 0;
    font-size: {{ block.settings.feature_title_font_size }}px;
    font-weight: {{ block.settings.feature_title_font_weight }};
    letter-spacing: {{ block.settings.feature_title_letter_spacing }}px;
    text-transform: uppercase;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    margin: 0 0 {{ block.settings.title_description_spacing }}px 0;
    line-height: 1.2;
  }

  .ai-media-strip-media-wrapper-{{ ai_gen_id }}.active .ai-media-strip-feature-content-{{ ai_gen_id }} {
    transform: translateY(calc(-1 * ({{ block.settings.description_font_size }} + {{ block.settings.title_description_spacing }} + 40)px));
  }

  .ai-media-strip-info-icon-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.info_icon_offset }}px;
    right: {{ block.settings.info_icon_offset }}px;
    width: {{ block.settings.info_icon_size }}px;
    height: {{ block.settings.info_icon_size }}px;
    background: none;
    border: none;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 0;
    flex-shrink: 0;
    opacity: {{ icon_opacity }};
  }

  .ai-media-strip-info-icon-{{ ai_gen_id }}:hover {
    transform: scale(1.15) translateY(-3px);
  }

  .ai-media-strip-info-icon-{{ ai_gen_id }}:active {
    transform: scale(0.98) translateY(0);
  }

  .ai-media-strip-info-icon-svg-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.15));
    transition: filter 0.4s ease;
  }

  .ai-media-strip-info-icon-{{ ai_gen_id }}:hover .ai-media-strip-info-icon-svg-{{ ai_gen_id }} {
    filter: drop-shadow(0 12px 40px rgba(0, 0, 0, 0.25));
  }

  .ai-media-strip-description-overlay-{{ ai_gen_id }} {
    position: static;
    height: auto;
    background-color: transparent;
    opacity: 0;
    padding: 0;
    margin: 0;
    overflow: hidden;
    transition: max-height 0.6s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 4;
    max-height: 0;
  }

  .ai-media-strip-description-overlay-{{ ai_gen_id }}.active {
    max-height: 300px;
    opacity: 1;
  }

  .ai-media-strip-description-content-{{ ai_gen_id }} {
    animation: slideUp 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ai-media-strip-description-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    font-weight: {{ block.settings.description_font_weight }};
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.7;
    letter-spacing: 0.3px;
    position: relative;
    z-index: 4;
  }

  .ai-media-strip-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 1;
  }

  .ai-media-strip-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @media (hover: hover) and (min-width: 750px) {
    .ai-media-strip-info-icon-{{ ai_gen_id }} {
      display: none;
    }

    .ai-media-strip-media-wrapper-{{ ai_gen_id }}:hover::after {
      opacity: 1;
    }

    .ai-media-strip-media-wrapper-{{ ai_gen_id }}:hover .ai-media-strip-feature-content-{{ ai_gen_id }} {
      transform: translateY(calc(-1 * ({{ block.settings.description_font_size }} + {{ block.settings.title_description_spacing }} + 40)px));
    }

    .ai-media-strip-media-wrapper-{{ ai_gen_id }}:hover .ai-media-strip-description-overlay-{{ ai_gen_id }} {
      max-height: 300px;
      opacity: 1;
    }
  }

  @media (hover: none) or (max-width: 749px) {
    .ai-media-strip-info-icon-{{ ai_gen_id }} {
      display: flex;
    }

    .ai-media-strip-item-{{ ai_gen_id }} {
      width: {{ block.settings.item_width_mobile }}px;
    }

    .ai-media-strip-media-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.item_height_mobile }}px;
    }

    .ai-media-strip-wrapper-{{ ai_gen_id }} {
      margin-left: {{ block.settings.start_spacing_mobile }}px;
      margin-right: {{ block.settings.item_spacing }}px;
    }

    .ai-media-strip-header-{{ ai_gen_id }} {
      margin-left: {{ block.settings.start_spacing_mobile }}px;
      margin-right: {{ block.settings.item_spacing }}px;
    }

    .ai-media-strip-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size_mobile }}px;
    }

    .ai-media-strip-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_font_size_mobile }}px;
    }
  }
{% endstyle %}

<media-feature-strip-{{ ai_gen_id }}
  class="ai-media-strip-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.section_title != blank or block.settings.section_subtitle != blank %}
    <div class="ai-media-strip-header-{{ ai_gen_id }}">
      {% if block.settings.section_title != blank %}
        <h2 class="ai-media-strip-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
      {% endif %}
      {% if block.settings.section_subtitle != blank %}
        <p class="ai-media-strip-subtitle-{{ ai_gen_id }}">{{ block.settings.section_subtitle }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-media-strip-wrapper-{{ ai_gen_id }}">
    <div class="ai-media-strip-container-{{ ai_gen_id }}">
      {% if feature_items and feature_items.size > 0 %}
        {% assign max_items_val = block.settings.max_items | default:6 %}
        {% for feature in feature_items limit:max_items_val %}
          {% assign f_title = feature.title %}
          {% assign f_desc = feature.description %}
          {% assign f_imgobj = feature.video_or_image %}

          {% assign f_imgsrc = '' %}
          {% assign f_is_video = false %}
          
          {% if f_imgobj != blank %}
            {% assign file_url_str = f_imgobj | file_url %}
            {% assign f_imgsrc = file_url_str %}
            
            {% if f_imgsrc contains '.mp4' or f_imgsrc contains '.webm' or f_imgsrc contains '.mov' or f_imgsrc contains '.avi' %}
              {% assign f_is_video = true %}
            {% endif %}
          {% endif %}

          {% if f_title != blank or f_imgsrc != blank %}
            <div class="ai-media-strip-item-{{ ai_gen_id }}" data-item="{{ forloop.index }}">
              <div class="ai-media-strip-media-wrapper-{{ ai_gen_id }}">
                {% if f_imgsrc != blank %}
                  {% if f_is_video %}
                    <video class="ai-media-strip-video-{{ ai_gen_id }}" autoplay muted loop playsinline disablepictureinpicture controlsList="nodownload" preload="metadata">
                      <source src="{{ f_imgsrc }}" type="video/mp4">
                      Tu navegador no soporta HTML5 video.
                    </video>
                  {% else %}
                    <img src="{{ f_imgsrc }}" alt="{{ f_title | escape }}" class="ai-media-strip-image-{{ ai_gen_id }}" loading="lazy">
                  {% endif %}
                {% else %}
                  <div class="ai-media-strip-placeholder-{{ ai_gen_id }}">{{ 'image' | placeholder_svg_tag }}</div>
                {% endif %}

                <div class="ai-media-strip-feature-content-{{ ai_gen_id }}">
                  {% if f_title != blank %}
                    <div class="ai-media-strip-feature-title-{{ ai_gen_id }}">{{ f_title }}</div>
                  {% endif %}

                  {% if f_desc != blank %}
                    <div class="ai-media-strip-description-overlay-{{ ai_gen_id }}" data-description="{{ forloop.index }}">
                      <div class="ai-media-strip-description-content-{{ ai_gen_id }}">
                        <div class="ai-media-strip-description-text-{{ ai_gen_id }}">{{ f_desc }}</div>
                      </div>
                    </div>
                  {% endif %}
                </div>

                <button class="ai-media-strip-info-icon-{{ ai_gen_id }}" data-info="{{ forloop.index }}" type="button" aria-label="More information about {{ f_title }}" aria-expanded="false">
                  <svg class="ai-media-strip-info-icon-svg-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <defs><mask id="knockout-{{ ai_gen_id }}-{{ forloop.index }}"><rect width="24" height="24" fill="white"/><circle cx="12" cy="6" r="1.5" fill="black"/><rect x="11" y="9" width="2" height="8" fill="black"/></mask></defs>
                    <circle cx="12" cy="12" r="12" fill="{{ block.settings.info_icon_bg_color }}" mask="url(#knockout-{{ ai_gen_id }}-{{ forloop.index }})"/>
                  </svg>
                </button>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      {% else %}
        {% if block.settings.media_type_1 != 'none' %}
          <div class="ai-media-strip-item-{{ ai_gen_id }}" data-item="1">
            <div class="ai-media-strip-media-wrapper-{{ ai_gen_id }}">
              {% if block.settings.media_type_1 == 'image' %}
                {% if block.settings.image_1 %}
                  <img src="{{ block.settings.image_1 | image_url: width: 800 }}" alt="{{ block.settings.image_1.alt | escape }}" class="ai-media-strip-image-{{ ai_gen_id }}" loading="lazy" width="{{ block.settings.image_1.width }}" height="{{ block.settings.image_1.height }}">
                {% else %}
                  <div class="ai-media-strip-placeholder-{{ ai_gen_id }}">{{ 'image' | placeholder_svg_tag }}</div>
                {% endif %}
              {% elsif block.settings.media_type_1 == 'video' %}
                {% if block.settings.video_1 %}
                  <video class="ai-media-strip-video-{{ ai_gen_id }}" autoplay muted loop playsinline disablepictureinpicture controlsList="nodownload" preload="metadata">
                    <source src="{{ block.settings.video_1 }}" type="video/mp4">
                    Tu navegador no soporta HTML5 video.
                  </video>
                {% else %}
                  <div class="ai-media-strip-placeholder-{{ ai_gen_id }}">{{ 'image' | placeholder_svg_tag }}</div>
                {% endif %}
              {% endif %}

              <div class="ai-media-strip-feature-content-{{ ai_gen_id }}">
                {% if block.settings.feature_title_1 != blank %}
                  <div class="ai-media-strip-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_title_1 }}</div>
                {% endif %}

                {% if block.settings.feature_description_1 != blank %}
                  <div class="ai-media-strip-description-overlay-{{ ai_gen_id }}" data-description="1">
                    <div class="ai-media-strip-description-content-{{ ai_gen_id }}">
                      <div class="ai-media-strip-description-text-{{ ai_gen_id }}">{{ block.settings.feature_description_1 }}</div>
                    </div>
                  </div>
                {% endif %}
              </div>

              <button class="ai-media-strip-info-icon-{{ ai_gen_id }}" data-info="1" type="button" aria-label="More information about {{ block.settings.feature_title_1 }}" aria-expanded="false">
                <svg class="ai-media-strip-info-icon-svg-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <defs><mask id="knockout-{{ ai_gen_id }}-1"><rect width="24" height="24" fill="white"/><circle cx="12" cy="6" r="1.5" fill="black"/><rect x="11" y="9" width="2" height="8" fill="black"/></mask></defs>
                  <circle cx="12" cy="12" r="12" fill="{{ block.settings.info_icon_bg_color }}" mask="url(#knockout-{{ ai_gen_id }}-1)"/>
                </svg>
              </button>
            </div>
          </div>
        {% endif %}

        {% if block.settings.media_type_2 != 'none' %}
          <div class="ai-media-strip-item-{{ ai_gen_id }}" data-item="2">
            <div class="ai-media-strip-media-wrapper-{{ ai_gen_id }}">
              {% if block.settings.media_type_2 == 'image' %}
                {% if block.settings.image_2 %}
                  <img src="{{ block.settings.image_2 | image_url: width: 800 }}" alt="{{ block.settings.image_2.alt | escape }}" class="ai-media-strip-image-{{ ai_gen_id }}" loading="lazy" width="{{ block.settings.image_2.width }}" height="{{ block.settings.image_2.height }}">
                {% else %}
                  <div class="ai-media-strip-placeholder-{{ ai_gen_id }}">{{ 'image' | placeholder_svg_tag }}</div>
                {% endif %}
              {% elsif block.settings.media_type_2 == 'video' %}
                {% if block.settings.video_2 %}
                  <video class="ai-media-strip-video-{{ ai_gen_id }}" autoplay muted loop playsinline disablepictureinpicture controlsList="nodownload" preload="metadata">
                    <source src="{{ block.settings.video_2 }}" type="video/mp4">
                    Tu navegador no soporta HTML5 video.
                  </video>
                {% else %}
                  <div class="ai-media-strip-placeholder-{{ ai_gen_id }}">{{ 'image' | placeholder_svg_tag }}</div>
                {% endif %}
              {% endif %}

              <div class="ai-media-strip-feature-content-{{ ai_gen_id }}">
                {% if block.settings.feature_title_2 != blank %}
                  <div class="ai-media-strip-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_title_2 }}</div>
                {% endif %}

                {% if block.settings.feature_description_2 != blank %}
                  <div class="ai-media-strip-description-overlay-{{ ai_gen_id }}" data-description="2">
                    <div class="ai-media-strip-description-content-{{ ai_gen_id }}">
                      <div class="ai-media-strip-description-text-{{ ai_gen_id }}">{{ block.settings.feature_description_2 }}</div>
                    </div>
                  </div>
                {% endif %}
              </div>

              <button class="ai-media-strip-info-icon-{{ ai_gen_id }}" data-info="2" type="button" aria-label="More information about {{ block.settings.feature_title_2 }}" aria-expanded="false">
                <svg class="ai-media-strip-info-icon-svg-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <defs><mask id="knockout-{{ ai_gen_id }}-2"><rect width="24" height="24" fill="white"/><circle cx="12" cy="6" r="1.5" fill="black"/><rect x="11" y="9" width="2" height="8" fill="black"/></mask></defs>
                  <circle cx="12" cy="12" r="12" fill="{{ block.settings.info_icon_bg_color }}" mask="url(#knockout-{{ ai_gen_id }}-2)"/>
                </svg>
              </button>
            </div>
          </div>
        {% endif %}

        {% if block.settings.media_type_3 != 'none' %}
          <div class="ai-media-strip-item-{{ ai_gen_id }}" data-item="3">
            <div class="ai-media-strip-media-wrapper-{{ ai_gen_id }}">
              {% if block.settings.media_type_3 == 'image' %}
                {% if block.settings.image_3 %}
                  <img src="{{ block.settings.image_3 | image_url: width: 800 }}" alt="{{ block.settings.image_3.alt | escape }}" class="ai-media-strip-image-{{ ai_gen_id }}" loading="lazy" width="{{ block.settings.image_3.width }}" height="{{ block.settings.image_3.height }}">
                {% else %}
                  <div class="ai-media-strip-placeholder-{{ ai_gen_id }}">{{ 'image' | placeholder_svg_tag }}</div>
                {% endif %}
              {% elsif block.settings.media_type_3 == 'video' %}
                {% if block.settings.video_3 %}
                  <video class="ai-media-strip-video-{{ ai_gen_id }}" autoplay muted loop playsinline disablepictureinpicture controlsList="nodownload" preload="metadata">
                    <source src="{{ block.settings.video_3 }}" type="video/mp4">
                    Tu navegador no soporta HTML5 video.
                  </video>
                {% else %}
                  <div class="ai-media-strip-placeholder-{{ ai_gen_id }}">{{ 'image' | placeholder_svg_tag }}</div>
                {% endif %}
              {% endif %}

              <div class="ai-media-strip-feature-content-{{ ai_gen_id }}">
                {% if block.settings.feature_title_3 != blank %}
                  <div class="ai-media-strip-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_title_3 }}</div>
                {% endif %}

                {% if block.settings.feature_description_3 != blank %}
                  <div class="ai-media-strip-description-overlay-{{ ai_gen_id }}" data-description="3">
                    <div class="ai-media-strip-description-content-{{ ai_gen_id }}">
                      <div class="ai-media-strip-description-text-{{ ai_gen_id }}">{{ block.settings.feature_description_3 }}</div>
                    </div>
                  </div>
                {% endif %}
              </div>

              <button class="ai-media-strip-info-icon-{{ ai_gen_id }}" data-info="3" type="button" aria-label="More information about {{ block.settings.feature_title_3 }}" aria-expanded="false">
                <svg class="ai-media-strip-info-icon-svg-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <defs><mask id="knockout-{{ ai_gen_id }}-3"><rect width="24" height="24" fill="white"/><circle cx="12" cy="6" r="1.5" fill="black"/><rect x="11" y="9" width="2" height="8" fill="black"/></mask></defs>
                  <circle cx="12" cy="12" r="12" fill="{{ block.settings.info_icon_bg_color }}" mask="url(#knockout-{{ ai_gen_id }}-3)"/>
                </svg>
              </button>
            </div>
          </div>
        {% endif %}

        {% if block.settings.media_type_4 != 'none' %}
          <div class="ai-media-strip-item-{{ ai_gen_id }}" data-item="4">
            <div class="ai-media-strip-media-wrapper-{{ ai_gen_id }}">
              {% if block.settings.media_type_4 == 'image' %}
                {% if block.settings.image_4 %}
                  <img src="{{ block.settings.image_4 | image_url: width: 800 }}" alt="{{ block.settings.image_4.alt | escape }}" class="ai-media-strip-image-{{ ai_gen_id }}" loading="lazy" width="{{ block.settings.image_4.width }}" height="{{ block.settings.image_4.height }}">
                {% else %}
                  <div class="ai-media-strip-placeholder-{{ ai_gen_id }}">{{ 'image' | placeholder_svg_tag }}</div>
                {% endif %}
              {% elsif block.settings.media_type_4 == 'video' %}
                {% if block.settings.video_4 %}
                  <video class="ai-media-strip-video-{{ ai_gen_id }}" autoplay muted loop playsinline disablepictureinpicture controlsList="nodownload" preload="metadata">
                    <source src="{{ block.settings.video_4 }}" type="video/mp4">
                    Tu navegador no soporta HTML5 video.
                  </video>
                {% else %}
                  <div class="ai-media-strip-placeholder-{{ ai_gen_id }}">{{ 'image' | placeholder_svg_tag }}</div>
                {% endif %}
              {% endif %}

              <div class="ai-media-strip-feature-content-{{ ai_gen_id }}">
