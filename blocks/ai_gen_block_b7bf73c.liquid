<script>
  (function() {
    class MediaFeatureStrip{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.container = this.querySelector('.ai-media-strip-container-{{ ai_gen_id }}');
        this.id = '{{ ai_gen_id }}';
      }

      connectedCallback() {
        this.setupScrollMomentum();
        this.setupVideos();
        this.setupTouchInteractions();
      }

      setupScrollMomentum() {
        if (!this.container) return;

        let isDown = false;
        let startX;
        let scrollLeft;
        let velocity = 0;
        let momentumID;

        this.container.addEventListener('mousedown', (e) => {
          isDown = true;
          this.container.style.cursor = 'grabbing';
          startX = e.pageX - this.container.offsetLeft;
          scrollLeft = this.container.scrollLeft;
          cancelMomentumTracking();
        });

        this.container.addEventListener('mouseleave', () => {
          isDown = false;
          this.container.style.cursor = 'grab';
        });

        this.container.addEventListener('mouseup', () => {
          isDown = false;
          this.container.style.cursor = 'grab';
          beginMomentumTracking();
        });

        this.container.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - this.container.offsetLeft;
          const walk = (x - startX) * 1.5;
          const prevScrollLeft = this.container.scrollLeft;
          this.container.scrollLeft = scrollLeft - walk;
          velocity = this.container.scrollLeft - prevScrollLeft;
        });

        const beginMomentumTracking = () => {
          cancelMomentumTracking();
          momentumID = requestAnimationFrame(momentumLoop);
        };

        const cancelMomentumTracking = () => {
          cancelAnimationFrame(momentumID);
        };

        const momentumLoop = () => {
          this.container.scrollLeft += velocity;
          velocity *= 0.95;
          if (Math.abs(velocity) > 0.5) {
            momentumID = requestAnimationFrame(momentumLoop);
          }
        };

        this.container.style.cursor = 'grab';
      }

      setupVideos() {
        const videos = this.querySelectorAll('.ai-media-strip-video-{{ ai_gen_id }}');
        
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            const video = entry.target;
            if (entry.isIntersecting) {
              video.muted = true;
              const playPromise = video.play();
              if (playPromise !== undefined) {
                playPromise.catch(err => {
                  console.log('Autoplay prevented:', err);
                });
              }
            } else {
              video.pause();
            }
          });
        }, { threshold: 0.5 });

        videos.forEach(video => {
          observer.observe(video);
        });
      }

      setupTouchInteractions() {
        const buttons = this.querySelectorAll('[data-info]');
        
        buttons.forEach(button => {
          button.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            
            const itemNum = button.getAttribute('data-info');
            const wrapper = button.closest('.ai-media-strip-media-wrapper-{{ ai_gen_id }}');
            const overlay = wrapper.querySelector(`[data-description="${itemNum}"]`);
            
            if (!overlay) return;

            const isActive = overlay.classList.contains('active');
            
            // Cerrar todos primero
            this.querySelectorAll('.ai-media-strip-media-wrapper-{{ ai_gen_id }}.active')
              .forEach(el => el.classList.remove('active'));
            
            this.querySelectorAll('.ai-media-strip-description-overlay-{{ ai_gen_id }}.active').forEach(el => {
              el.classList.remove('active');
            });

            // Abrir actual si no estaba activo
            if (!isActive) {
              wrapper.classList.add('active');
              overlay.classList.add('active');
              button.setAttribute('aria-expanded', 'true');
            } else {
              button.setAttribute('aria-expanded', 'false');
            }
          });

          button.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              button.click();
            }
          });
        });

        document.addEventListener('click', (e) => {
          const strip = e.target.closest('media-feature-strip-{{ ai_gen_id }}');
          if (!strip) {
            this.querySelectorAll('.ai-media-strip-media-wrapper-{{ ai_gen_id }}.active').forEach(wrapper => {
              wrapper.classList.remove('active');
              const overlays = wrapper.querySelectorAll('.ai-media-strip-description-overlay-{{ ai_gen_id }}.active');
              overlays.forEach(overlay => overlay.classList.remove('active'));
              const button = wrapper.querySelector('[data-info]');
              if (button) button.setAttribute('aria-expanded', 'false');
            });
          }
        });
      }
    }

    customElements.define('media-feature-strip-{{ ai_gen_id }}', MediaFeatureStrip{{ ai_gen_id }});
  })();
</script>

