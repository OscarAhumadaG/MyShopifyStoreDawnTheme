{% assign ai_gen_id = block.id | replace: '_' , '' | replace: '-', '' | downcase %}

<style>
/* ===== Wrapper (alineación y paddings) ===== */
.ai-t-wrap-{{ ai_gen_id }}{
  box-sizing:border-box;
  width:100%;
  margin-inline:auto;

  /* Paddings controlados por settings */
  padding-top: {{ block.settings.section_padding_top | default:40 }}px;
  padding-bottom: {{ block.settings.section_padding_bottom | default:40 }}px;
  padding-left: {{ block.settings.gutter_x_desktop | default:32 }}px;
  padding-right: {{ block.settings.gutter_x_desktop | default:32 }}px;
}

/* ===== Cabecera con GAP (controla espacio entre título/subtítulo) ===== */
.ai-t-head-{{ ai_gen_id }}{
  display:flex;
  flex-direction:column;
  align-items:center;
  text-align:center;
  row-gap: {{ block.settings.title_subtitle_spacing | default:10 }}px;
  margin-bottom:40px;
}

/* Reset márgenes de <p> para no aumentar el gap */
.ai-t-head-{{ ai_gen_id }} p {
  margin:0;
}

/* Título Desktop */
.ai-t-title-d-{{ ai_gen_id }}{
  font-size:{{ block.settings.title_size_desktop | default:32 }}px;
  color:{{ block.settings.title_color | default:'#121212' }};
  margin:0;
}

/* Título Mobile */
.ai-t-title-m-{{ ai_gen_id }}{
  display:none;
  font-size:{{ block.settings.title_size_mobile | default:24 }}px;
  color:{{ block.settings.title_color | default:'#121212' }};
  margin:0;
}

/* Subtítulo */
.ai-t-subtitle-{{ ai_gen_id }}{
  font-size:{{ block.settings.subtitle_size | default:16 }}px;
  color:{{ block.settings.subtitle_color | default:'#666666' }};
  margin:0;
}

/* ===== Grid de tarjetas (Desktop) ===== */
.ai-t-grid-{{ ai_gen_id }}{
  display:grid;
  grid-template-columns:repeat({{ block.settings.columns_desktop | default:3 }},1fr);
  gap:{{ block.settings.card_spacing | default:20 }}px;
}

/* ===== Contenedor Carousel (Mobile) ===== */
.ai-t-carousel-wrapper-{{ ai_gen_id }}{
  display:none;
  position:relative;
}

.ai-t-carousel-{{ ai_gen_id }}{
  display:flex;
  overflow-x:auto;
  overflow-y:hidden;
  scroll-behavior:smooth;
  -webkit-overflow-scrolling:touch;
  gap:{{ block.settings.card_spacing_mobile | default:14 }}px;
  padding-bottom:20px;
  padding-top:6px;        /* ← FIX: espacio para el translateY del hover */
  margin-top:-6px;        /* ← FIX: compensa el espacio visual */
  
  /* Ocultar scrollbar nativo */
  scrollbar-width:none;
  -ms-overflow-style:none;
}

.ai-t-carousel-{{ ai_gen_id }}::-webkit-scrollbar {
  display:none;
}

/* Scroll snap para mejor experiencia */
.ai-t-carousel-{{ ai_gen_id }}{
  scroll-snap-type:x mandatory;
}

/* ===== Indicador de más contenido (gradiente derecha) ===== */
.ai-t-scroll-indicator-{{ ai_gen_id }}{
  position:absolute;
  top:0;
  right:0;
  bottom:20px;
  width:40px;
  background:linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.95) 60%, rgba(255,255,255,1) 100%);
  pointer-events:none;
  opacity:1;
  transition:opacity 0.3s ease;
  z-index:10;
}

.ai-t-scroll-indicator-{{ ai_gen_id }}.hidden{
  opacity:0;
  pointer-events:none;
}

/* Puntitos dentro del indicador */
.ai-t-scroll-indicator-{{ ai_gen_id }}::after{
  content:'';
  position:absolute;
  right:12px;
  top:50%;
  transform:translateY(-50%);
  width:8px;
  height:8px;
  border-radius:50%;
  background:{{ block.settings.scroll_indicator_color | default:'#008060' }};
  box-shadow:0 -12px 0 -6px {{ block.settings.scroll_indicator_color | default:'#008060' }}, 
             0 12px 0 -6px {{ block.settings.scroll_indicator_color | default:'#008060' }};
  animation:ai-t-pulse-{{ ai_gen_id }} 1.5s ease-in-out infinite;
}

@keyframes ai-t-pulse-{{ ai_gen_id }}{
  0%, 100% {
    opacity:0.6;
    transform:translateY(-50%) translateX(0);
  }
  50% {
    opacity:1;
    transform:translateY(-50%) translateX(4px);
  }
}

/* ===== Tarjeta ===== */
.ai-t-card-{{ ai_gen_id }}{
  background:{{ block.settings.card_bg_color | default:'#ffffff' }};
  border-radius:{{ block.settings.card_border_radius | default:12 }}px;
  padding:{{ block.settings.card_padding | default:22 }}px;
  border:{{ block.settings.card_border_width | default:1 }}px solid {{ block.settings.card_border_color | default:'#EAEAEA' }};
  box-shadow:0 4px 14px rgba(0,0,0,.06);
  display:grid;
  grid-template-rows: auto auto auto auto 1fr;
  align-items:start;
  justify-items:center;
  text-align:center;
  transition:.2s ease;
  scroll-snap-align:center;
  scroll-snap-stop:always;
}

.ai-t-card-{{ ai_gen_id }}:hover{
  transform:translateY(-4px);
  border-color:{{ block.settings.card_border_hover_color | default:'#008060' }};
}

/* ===== Avatar ===== */
.ai-t-imgw-{{ ai_gen_id }}{
  width:{{ block.settings.image_size | default:80 }}px;
  height:{{ block.settings.image_size | default:80 }}px;
  border-radius:50%;
  overflow:hidden;
  margin-bottom:14px;
  flex-shrink:0;
}

.ai-t-img-{{ ai_gen_id }}{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
}

/* ===== Nombre ===== */
.ai-t-name-{{ ai_gen_id }}{
  font-size:{{ block.settings.name_size | default:16 }}px;
  color:{{ block.settings.name_color | default:'#121212' }};
  font-weight:600;
  margin:0 0 6px;
  width:100%;
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
  text-align:center;
}

/* ===== Badge verificada ===== */
.ai-t-badge-{{ ai_gen_id }}{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:6px;
  font-size:{{ block.settings.verified_size | default:13 }}px;
  color:{{ block.settings.verified_color | default:'#008060' }};
  margin-bottom:8px;
  font-weight:500;
  width:100%;
  white-space:nowrap;
}

/* ===== Rating ===== */
.ai-t-rate-{{ ai_gen_id }}{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:8px;
  margin-bottom:12px;
  flex-wrap:nowrap;
  white-space:nowrap;
  width:100%;
}

.ai-t-stars-wrap-{{ ai_gen_id }}{
  position:relative;
  display:inline-block;
  font-size:{{ block.settings.star_size | default:20 }}px;
  line-height:1;
  flex-shrink:0;
  white-space:nowrap;
}

.ai-t-stars-bg-{{ ai_gen_id }}{
  color:{{ block.settings.star_empty_color | default:'#E0E0E0' }};
  white-space:nowrap;
}

.ai-t-stars-fill-{{ ai_gen_id }}{
  position:absolute;
  top:0;
  left:0;
  white-space:nowrap;
  overflow:hidden;
  color:{{ block.settings.star_fill_color | default:'#FFD700' }};
}

.ai-t-rating-number-{{ ai_gen_id }}{
  font-size:14px;
  font-weight:600;
  color:#333;
  flex-shrink:0;
  white-space:nowrap;
}

/* ===== Texto del testimonio ===== */
.ai-t-text-{{ ai_gen_id }}{
  font-size:{{ block.settings.text_size | default:14 }}px;
  color:{{ block.settings.text_color | default:'#666666' }};
  line-height:1.6;
  margin:0;
}

/* ===== Indicador de scroll (puntitos) ===== */
.ai-t-scroll-dots-{{ ai_gen_id }}{
  display:none;
  justify-content:center;
  align-items:center;
  gap:8px;
  margin-top:24px;
}

.ai-t-dot-{{ ai_gen_id }}{
  width:8px;
  height:8px;
  border-radius:50%;
  background:{{ block.settings.dot_inactive_color | default:'#EAEAEA' }};
  cursor:pointer;
  transition:.3s ease;
}

.ai-t-dot-{{ ai_gen_id }}.active{
  background:{{ block.settings.dot_active_color | default:'#008060' }};
  width:24px;
  border-radius:4px;
}

/* ===== Mobile ===== */
@media (max-width:749px){
  .ai-t-head-{{ ai_gen_id }}{
    row-gap: {{ block.settings.title_subtitle_spacing_mobile | default:10 }}px;
  }
  .ai-t-title-d-{{ ai_gen_id }}{ display:none; }
  .ai-t-title-m-{{ ai_gen_id }}{ display:block; }

  .ai-t-grid-{{ ai_gen_id }}{
    display:none;
  }

  .ai-t-carousel-wrapper-{{ ai_gen_id }}{
    display:block;
  }

  .ai-t-carousel-{{ ai_gen_id }}{
    display:flex;
    gap:{{ block.settings.card_spacing_mobile | default:14 }}px;
  }

  .ai-t-card-{{ ai_gen_id }}{
    flex-shrink:0;
    width:calc((100vw - {{ block.settings.gutter_x_mobile | default:16 }}px * 2 - {{ block.settings.card_spacing_mobile | default:14 }}px) / 2 - 8px);
    min-width:160px;
    padding:{{ block.settings.card_padding_mobile | default:18 }}px;
  }

  .ai-t-scroll-dots-{{ ai_gen_id }}{
    display:flex;
  }

  .ai-t-wrap-{{ ai_gen_id }}{
    padding-top: {{ block.settings.section_padding_top | default:28 }}px;
    padding-bottom: {{ block.settings.section_padding_bottom | default:28 }}px;
    padding-left: {{ block.settings.gutter_x_mobile | default:16 }}px;
    padding-right: {{ block.settings.gutter_x_mobile | default:16 }}px;
  }
}
</style>

{%- assign anchor_id = block.settings.anchor_id | default: 'testimonios-productos' -%}

<div class="ai-t-wrap-{{ ai_gen_id }}" id="{{ anchor_id }}">

  {% if block.settings.title_desktop != blank or block.settings.subtitle != blank %}
    <div class="ai-t-head-{{ ai_gen_id }}">
      {% if block.settings.title_desktop != blank %}
        <div class="ai-t-title-d-{{ ai_gen_id }}">
          {{ block.settings.title_desktop }}
        </div>
      {% endif %}

      {% if block.settings.title_mobile != blank %}
        <div class="ai-t-title-m-{{ ai_gen_id }}">
          {{ block.settings.title_mobile }}
        </div>
      {% endif %}

      {% if block.settings.subtitle != blank %}
        <div class="ai-t-subtitle-{{ ai_gen_id }}">
          {{ block.settings.subtitle }}
        </div>
      {% endif %}
    </div>
  {% endif %}

  {% assign ns_cfg  = block.settings.meta_ns  | default:'custom' %}
  {% assign key_cfg = block.settings.meta_key | default:'testimonial' %}
  {% assign mf = product.metafields[ns_cfg][key_cfg] %}

  {% if mf and mf.value and mf.type contains 'list.' %}
    {% assign list = mf.value %}
  {% endif %}

  {% assign max_items_val = block.settings.max_items | default:6 %}

  {% if list and list.size > 0 %}
    <!-- Grid Desktop -->
    <div class="ai-t-grid-{{ ai_gen_id }}">
    {% for r in list limit:max_items_val %}
      {% assign t_name   = r.name   | default:r.name.value %}
      {% assign t_text   = r.text   | default:r.text.value %}
      {% assign t_rating = r.rating | default:r.rating.value %}
      {% assign t_imgobj = r.image  | default:r.image.value %}

      {% assign rating_raw = t_rating | default:'' %}
      {% assign rating_str = rating_raw | replace:',','.' | strip %}
      {% assign has_rating = false %}
      {% if rating_str != '' %}
        {% assign rating_num = rating_str | times:1.0 %}
        {% assign has_rating = true %}
        {% if rating_num > 5 %}{% assign rating_num = 5 %}{% endif %}
        {% if rating_num < 0 %}{% assign rating_num = 0 %}{% endif %}
      {% endif %}

      {% assign t_imgsrc = '' %}
      {% if t_imgobj %}
        {% assign t_imgsrc = t_imgobj | image_url: width:300 %}
        {% if t_imgsrc == blank %}
          {% assign t_imgsrc = t_imgobj | file_url %}
        {% endif %}
      {% endif %}

      <div class="ai-t-card-{{ ai_gen_id }}">
        {% if t_imgsrc != blank %}
          {% assign img_size = block.settings.image_size | default:80 %}
          <div class="ai-t-imgw-{{ ai_gen_id }}">
            <img
              src="{{ t_imgsrc }}"
              alt="{{ t_name | default:'Avatar de cliente' | escape }}"
              class="ai-t-img-{{ ai_gen_id }}"
              width="{{ img_size }}"
              height="{{ img_size }}"
              loading="lazy"
              decoding="async"
            >
          </div>
        {% endif %}

        {% if t_name %}
          <div class="ai-t-name-{{ ai_gen_id }}">{{ t_name }}</div>
        {% endif %}

        {% if block.settings.show_verified %}
          <div class="ai-t-badge-{{ ai_gen_id }}">
            ✓ {{ block.settings.verified_text | default:'Cliente verificada' }}
          </div>
        {% endif %}

        {% if has_rating %}
          <div class="ai-t-rate-{{ ai_gen_id }}">
            <div class="ai-t-stars-wrap-{{ ai_gen_id }}">
              <div class="ai-t-stars-bg-{{ ai_gen_id }}">★★★★★</div>
              <div class="ai-t-stars-fill-{{ ai_gen_id }}" style="width: {{ rating_num | times:20 }}%">
                ★★★★★
              </div>
            </div>
            <span class="ai-t-rating-number-{{ ai_gen_id }}">{{ rating_num }}</span>
          </div>
        {% endif %}

        {% if t_text %}
          <p class="ai-t-text-{{ ai_gen_id }}">{{ t_text }}</p>
        {% endif %}
      </div>

    {% endfor %}
    </div>

    <!-- Carousel Mobile -->
    <div class="ai-t-carousel-wrapper-{{ ai_gen_id }}" id="carousel-wrapper-{{ ai_gen_id }}">
      <div class="ai-t-carousel-{{ ai_gen_id }}" id="carousel-{{ ai_gen_id }}">
      {% for r in list limit:max_items_val %}
        {% assign t_name   = r.name   | default:r.name.value %}
        {% assign t_text   = r.text   | default:r.text.value %}
        {% assign t_rating = r.rating | default:r.rating.value %}
        {% assign t_imgobj = r.image  | default:r.image.value %}

        {% assign rating_raw = t_rating | default:'' %}
        {% assign rating_str = rating_raw | replace:',','.' | strip %}
        {% assign has_rating = false %}
        {% if rating_str != '' %}
          {% assign rating_num = rating_str | times:1.0 %}
          {% assign has_rating = true %}
          {% if rating_num > 5 %}{% assign rating_num = 5 %}{% endif %}
          {% if rating_num < 0 %}{% assign rating_num = 0 %}{% endif %}
        {% endif %}

        {% assign t_imgsrc = '' %}
        {% if t_imgobj %}
          {% assign t_imgsrc = t_imgobj | image_url: width:300 %}
          {% if t_imgsrc == blank %}
            {% assign t_imgsrc = t_imgobj | file_url %}
          {% endif %}
        {% endif %}

        <div class="ai-t-card-{{ ai_gen_id }}">
          {% if t_imgsrc != blank %}
            {% assign img_size = block.settings.image_size | default:80 %}
            <div class="ai-t-imgw-{{ ai_gen_id }}">
              <img
                src="{{ t_imgsrc }}"
                alt="{{ t_name | default:'Avatar de cliente' | escape }}"
                class="ai-t-img-{{ ai_gen_id }}"
                width="{{ img_size }}"
                height="{{ img_size }}"
                loading="lazy"
                decoding="async"
              >
            </div>
          {% endif %}

          {% if t_name %}
            <div class="ai-t-name-{{ ai_gen_id }}">{{ t_name }}</div>
          {% endif %}

          {% if block.settings.show_verified %}
            <div class="ai-t-badge-{{ ai_gen_id }}">
              ✓ {{ block.settings.verified_text | default:'Cliente verificada' }}
            </div>
          {% endif %}

          {% if has_rating %}
            <div class="ai-t-rate-{{ ai_gen_id }}">
              <div class="ai-t-stars-wrap-{{ ai_gen_id }}">
                <div class="ai-t-stars-bg-{{ ai_gen_id }}">★★★★★</div>
                <div class="ai-t-stars-fill-{{ ai_gen_id }}" style="width: {{ rating_num | times:20 }}%">
                  ★★★★★
                </div>
              </div>
              <span class="ai-t-rating-number-{{ ai_gen_id }}">{{ rating_num }}</span>
            </div>
          {% endif %}

          {% if t_text %}
            <p class="ai-t-text-{{ ai_gen_id }}">{{ t_text }}</p>
          {% endif %}
        </div>

      {% endfor %}
      </div>

      <!-- Indicador visual de más contenido -->
      <div class="ai-t-scroll-indicator-{{ ai_gen_id }}" id="scroll-indicator-{{ ai_gen_id }}"></div>
    </div>

    <!-- Indicadores de scroll (Dots) -->
    <div class="ai-t-scroll-dots-{{ ai_gen_id }}" id="dots-{{ ai_gen_id }}">
    {% for r in list limit:max_items_val %}
      <div class="ai-t-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}"></div>
    {% endfor %}
    </div>

  {% endif %}

</div>

<script>
(function() {
  const carouselId = '{{ ai_gen_id }}';
  const carousel = document.getElementById('carousel-' + carouselId);
  const dots = document.querySelectorAll('.ai-t-dot-' + carouselId);
  const indicator = document.getElementById('scroll-indicator-' + carouselId);

  if (!carousel) return;

  let isScrolling = false;

  function updateScrollIndicator() {
    if (!indicator) return;
    const hasMoreContent = carousel.scrollLeft < carousel.scrollWidth - carousel.offsetWidth - 20;
    if (hasMoreContent) {
      indicator.classList.remove('hidden');
    } else {
      indicator.classList.add('hidden');
    }
  }

  setTimeout(updateScrollIndicator, 100);
  window.addEventListener('resize', updateScrollIndicator);

  carousel.addEventListener('scroll', () => {
    updateScrollIndicator();
    if (isScrolling) return;
    if (dots.length > 0) {
      const cards = carousel.querySelectorAll('.ai-t-card-' + carouselId);
      const scrollLeft = carousel.scrollLeft;
      let currentIndex = 0;
      let minDistance = Infinity;
      cards.forEach((card, index) => {
        const cardCenter = card.offsetLeft + card.offsetWidth / 2;
        const carouselCenter = scrollLeft + carousel.offsetWidth / 2;
        const distance = Math.abs(cardCenter - carouselCenter);
        if (distance < minDistance) {
          minDistance = distance;
          currentIndex = index;
        }
      });
      dots.forEach((dot, index) => {
        dot.classList.toggle('active', index === currentIndex);
      });
    }
  }, { passive: true });

  if (dots.length > 0) {
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        isScrolling = true;
        const cards = carousel.querySelectorAll('.ai-t-card-' + carouselId);
        const targetCard = cards[index];
        if (targetCard) {
          const scrollPosition = targetCard.offsetLeft - (carousel.offsetWidth / 2) + (targetCard.offsetWidth / 2);
          carousel.scrollTo({ left: scrollPosition, behavior: 'smooth' });
          setTimeout(() => {
            isScrolling = false;
            updateScrollIndicator();
          }, 500);
        }
      });
    });
  }
})();
</script>

{% schema %}
{
  "name": "Testimonios de producto",
  "settings": [
    { "type": "header", "content": "Anchor (scroll link)" },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Section anchor ID",
      "default": "testimonios-productos",
      "info": "Must match the 'Testimonials section ID' in the Product Rating block. Used for scroll-to links."
    },

    { "type": "header", "content": "Ancho y espaciados del bloque" },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Espacio superior del bloque",
      "min": 0, "max": 200, "step": 5, "unit": "px", "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Espacio inferior del bloque",
      "min": 0, "max": 200, "step": 5, "unit": "px", "default": 40
    },
    {
      "type": "range",
      "id": "gutter_x_desktop",
      "label": "Gutter lateral desktop",
      "min": 0, "max": 64, "step": 2, "unit": "px", "default": 32
    },
    {
      "type": "range",
      "id": "gutter_x_mobile",
      "label": "Gutter lateral mobile",
      "min": 0, "max": 40, "step": 2, "unit": "px", "default": 16
    },

    { "type": "header", "content": "Títulos" },
    { "type": "richtext", "id": "title_desktop", "label": "Título desktop", "default": "<p>Lo que dicen nuestras clientas</p>" },
    { "type": "richtext", "id": "title_mobile", "label": "Título mobile", "default": "<p>Testimonios</p>" },
    { "type": "richtext", "id": "subtitle", "label": "Subtítulo", "default": "<p></p>" },

    {
      "type": "range",
      "id": "title_subtitle_spacing",
      "label": "Espacio entre título y subtítulo (desktop)",
      "min": 0, "max": 50, "step": 2, "unit": "px", "default": 10
    },
    {
      "type": "range",
      "id": "title_subtitle_spacing_mobile",
      "label": "Espacio entre título y subtítulo (mobile)",
      "min": 0, "max": 50, "step": 2, "unit": "px", "default": 10
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "label": "Tamaño título desktop",
      "min": 16, "max": 48, "step": 2, "unit": "px", "default": 32
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Tamaño título mobile",
      "min": 16, "max": 36, "step": 2, "unit": "px", "default": 24
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Tamaño subtítulo",
      "min": 12, "max": 24, "step": 1, "unit": "px", "default": 16
    },
    {
      "type": "range",
      "id": "subtitle_size_mobile",
      "label": "Tamaño subtítulo mobile",
      "min": 12, "max": 24, "step": 1, "unit": "px", "default": 14
    },
    { "type": "color", "id": "title_color", "label": "Color título", "default": "#121212" },
    { "type": "color", "id": "subtitle_color", "label": "Color subtítulo", "default": "#666666" },

    { "type": "header", "content": "Diseño (Grid)" },
    { "type": "range", "id": "columns_desktop", "label": "Columnas desktop", "min": 1, "max": 4, "step": 1, "default": 3 },
    { "type": "range", "id": "card_spacing", "label": "Espacio entre tarjetas (desktop)", "min": 8, "max": 40, "step": 2, "unit": "px", "default": 20 },
    { "type": "range", "id": "card_spacing_mobile", "label": "Espacio entre tarjetas (mobile)", "min": 4, "max": 32, "step": 2, "unit": "px", "default": 14 },
