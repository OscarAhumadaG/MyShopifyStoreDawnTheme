{% doc %}
  @prompt
    Genera una sección de barra de anuncio sencilla para Shopify 2.0 con un máximo de tres anuncios; cada anuncio debe permitir elegir tipografía (varios tipos de letra del tema o sistema, con opciones de peso y tamaño), fondo (color sólido) y estilo del texto (mayúsculas, espaciado, subrayado/opcional); la barra debe permitir modificar ancho y altura numéricamente (px/rem), ajustar la distancia entre anuncios con un control que acepte desde 0 para que queden pegados si se desea, y cambiar la forma de movimiento entre static, carousel (fade) y marquee (desplazamiento suave) con controles de velocidad y dirección; incluir campos por anuncio: headline (obligatorio), subtext ; todo con CSS/JS ligero sin dependencias, carga diferida, y un esquema de configuración simple y claro en el editor para que el comerciante pueda activar/ocultar, reordenar los tres anuncios y ajustar sus estilos rápidamente. pero quiero que tenga mas velocidad y se puedan pegar mas los anuncios, quiero que no haya tango gap entre los anuncios el resto esat super bien, no se porque pero cuando pasa al tercer anuncio hace como especie de un paron y se reinicia, yo no quiero eso quiero que continuamente este haciendo los mismo sin hacer  ese paron, ademas quiero que no haya tanto espacio entre anuncios
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-announcement-bar-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    position: relative;
    background-color: {{ block.settings.bar_background }};
  }

  .ai-announcement-bar-container-{{ ai_gen_id }} {
    width: {{ block.settings.bar_width }}{{ block.settings.bar_width_unit }};
    height: {{ block.settings.bar_height }}{{ block.settings.bar_height_unit }};
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .ai-announcement-bar-track-{{ ai_gen_id }} {
    display: flex;
    height: 100%;
    align-items: center;
    gap: {{ block.settings.announcement_gap }}px;
  }

  .ai-announcement-bar-item-{{ ai_gen_id }} {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 0 20px;
    height: 100%;
    opacity: 0;
    transition: opacity 0.5s ease;
    white-space: nowrap;
  }

  .ai-announcement-bar-item-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-announcement-bar-headline-{{ ai_gen_id }} {
    font-family: {{ block.settings.font_family }};
    font-weight: {{ block.settings.font_weight }};
    font-size: {{ block.settings.font_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    {% if block.settings.text_transform == 'uppercase' %}
      text-transform: uppercase;
    {% elsif block.settings.text_transform == 'lowercase' %}
      text-transform: lowercase;
    {% elsif block.settings.text_transform == 'capitalize' %}
      text-transform: capitalize;
    {% endif %}
    letter-spacing: {{ block.settings.letter_spacing }}px;
    {% if block.settings.text_decoration == 'underline' %}
      text-decoration: underline;
    {% endif %}
  }

  .ai-announcement-bar-subtext-{{ ai_gen_id }} {
    font-family: {{ block.settings.font_family }};
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.text_color }};
    margin: 4px 0 0;
    {% if block.settings.text_transform == 'uppercase' %}
      text-transform: uppercase;
    {% elsif block.settings.text_transform == 'lowercase' %}
      text-transform: lowercase;
    {% elsif block.settings.text_transform == 'capitalize' %}
      text-transform: capitalize;
    {% endif %}
    letter-spacing: {{ block.settings.letter_spacing }}px;
    {% if block.settings.text_decoration == 'underline' %}
      text-decoration: underline;
    {% endif %}
  }

  .ai-announcement-bar-track-{{ ai_gen_id }}.marquee {
    width: max-content;
    animation: ai-marquee-{{ ai_gen_id }} {{ block.settings.marquee_speed }}s linear infinite;
    {% if block.settings.marquee_direction == 'right' %}
      animation-direction: reverse;
    {% endif %}
  }

  @keyframes ai-marquee-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
{% endstyle %}

<announcement-bar-{{ ai_gen_id }}
  class="ai-announcement-bar-{{ ai_gen_id }}"
  data-mode="{{ block.settings.animation_mode }}"
  data-carousel-speed="{{ block.settings.carousel_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-announcement-bar-container-{{ ai_gen_id }}">
    <div class="ai-announcement-bar-track-{{ ai_gen_id }}" data-track>
      {% liquid
        assign active_announcements = 0
        for i in (1..3)
          assign enabled_key = 'announcement_' | append: i | append: '_enabled'
          if block.settings[enabled_key]
            assign active_announcements = active_announcements | plus: 1
          endif
        endfor
      %}

      {% for i in (1..3) %}
        {% liquid
          assign enabled_key = 'announcement_' | append: i | append: '_enabled'
          assign headline_key = 'announcement_' | append: i | append: '_headline'
          assign subtext_key = 'announcement_' | append: i | append: '_subtext'

          assign is_enabled = block.settings[enabled_key]
          assign headline = block.settings[headline_key]
          assign subtext = block.settings[subtext_key]
        %}

        {% if is_enabled %}
          <div class="ai-announcement-bar-item-{{ ai_gen_id }}" data-index="{{ forloop.index0 }}">
            {% if headline != blank %}
              <div class="ai-announcement-bar-headline-{{ ai_gen_id }}">{{ headline }}</div>
            {% endif %}
            {% if subtext != blank %}
              <div class="ai-announcement-bar-subtext-{{ ai_gen_id }}">{{ subtext }}</div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}

      {% if block.settings.animation_mode == 'marquee' and active_announcements > 0 %}
        {% for i in (1..3) %}
          {% liquid
            assign enabled_key = 'announcement_' | append: i | append: '_enabled'
            assign headline_key = 'announcement_' | append: i | append: '_headline'
            assign subtext_key = 'announcement_' | append: i | append: '_subtext'

            assign is_enabled = block.settings[enabled_key]
            assign headline = block.settings[headline_key]
            assign subtext = block.settings[subtext_key]
          %}

          {% if is_enabled %}
            <div class="ai-announcement-bar-item-{{ ai_gen_id }}" data-index="{{ forloop.index0 }}">
              {% if headline != blank %}
                <div class="ai-announcement-bar-headline-{{ ai_gen_id }}">{{ headline }}</div>
              {% endif %}
              {% if subtext != blank %}
                <div class="ai-announcement-bar-subtext-{{ ai_gen_id }}">{{ subtext }}</div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</announcement-bar-{{ ai_gen_id }}>

<script>
  (function() {
    class AnnouncementBar{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.mode = this.dataset.mode;
        this.carouselSpeed = parseInt(this.dataset.carouselSpeed) * 1000;
        this.track = this.querySelector('[data-track]');
        this.items = Array.from(this.querySelectorAll('.ai-announcement-bar-item-{{ ai_gen_id }}'));
        this.currentIndex = 0;
        this.interval = null;
      }

      connectedCallback() {
        if (this.items.length === 0) return;

        if (this.mode === 'static') {
          this.items[0].classList.add('active');
        } else if (this.mode === 'carousel') {
          this.startCarousel();
        } else if (this.mode === 'marquee') {
          this.startMarquee();
        }
      }

      startCarousel() {
        const visibleItems = this.items.filter((item, index) => index < this.items.length / 2);
        this.currentIndex = 0;
        visibleItems[this.currentIndex].classList.add('active');

        if (visibleItems.length > 1) {
          this.interval = setInterval(() => {
            visibleItems[this.currentIndex].classList.remove('active');
            this.currentIndex = (this.currentIndex + 1) % visibleItems.length;
            visibleItems[this.currentIndex].classList.add('active');
          }, this.carouselSpeed);
        }
      }

      startMarquee() {
        this.items.forEach(item => item.classList.add('active'));
        this.track.classList.add('marquee');
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);
        }
      }
    }

    customElements.define('announcement-bar-{{ ai_gen_id }}', AnnouncementBar{{ ai_gen_id }});
  })();
</script>

