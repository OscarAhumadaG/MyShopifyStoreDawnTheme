{% assign ai_gen_id = block.id | replace: '_' , '' | downcase %}

{% style %}
.ai-carousel-banner-{{ ai_gen_id }} {
  position: relative;
  width: 100%;
  overflow: hidden;
  background-color: {{ block.settings.background_color }};
  border-radius: {{ block.settings.border_radius }}px;
}

/* Alturas desktop - IMPORTANTE: sin min/max */
.ai-carousel-container-{{ ai_gen_id }} {
  position: relative;
  width: 100%;
  height: {{ block.settings.banner_height_desktop }}px !important;
}

/* Pista/diapositivas */
.ai-carousel-track-{{ ai_gen_id }} {
  display: flex;
  transition: transform 0.6s cubic-bezier(0.4,0,0.2,1);
  height: 100%;
  width: 100%;
}

.ai-carousel-slide-{{ ai_gen_id }} {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 100%;
  width: 100%;
  height: 100%;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}

/* Imagen */
.ai-carousel-slide-{{ ai_gen_id }} img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Placeholder */
.ai-carousel-placeholder-{{ ai_gen_id }} {
  width: 100%;
  height: 100%;
  background-color: #f4f4f4;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.ai-carousel-empty-state-{{ ai_gen_id }} {
  position: absolute;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  padding: 12px 20px;
  font-size: 14px;
  color: #666;
  text-align: center;
  pointer-events: none;
}

/* Overlay */
.ai-carousel-overlay-{{ ai_gen_id }} {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    to bottom,
    rgba(0,0,0,0) 0%,
    rgba(0,0,0,{{ block.settings.overlay_opacity | default: 50 | divided_by: 100.0 }}) 100%
  );
  pointer-events: none;
}

/* Contenido general (títulos/descripciones) */
.ai-carousel-content-{{ ai_gen_id }} {
  position: absolute;
  bottom: 60px;
  left: 50%;
  transform: translateX(-50%);
  text-align: center;
  color: {{ block.settings.text_color }};
  width: 90%;
  max-width: 800px;
  z-index: 2;
}

.ai-carousel-title-{{ ai_gen_id }} {
  font-size: {{ block.settings.title_size }}px;
  font-weight: 700;
  margin: 0 0 12px;
  line-height: 1.2;
}

.ai-carousel-description-{{ ai_gen_id }} {
  font-size: {{ block.settings.description_size }}px;
  margin: 0;
  line-height: 1.5;
}

/* Navegación */
.ai-carousel-nav-{{ ai_gen_id }} {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background-color: {{ block.settings.nav_button_color }};
  color: {{ block.settings.nav_icon_color }};
  border: none;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  z-index: 3;
  transition: all 0.3s ease;
  opacity: 0.9;
}

.ai-carousel-nav-{{ ai_gen_id }}:hover {
  opacity: 1;
  transform: translateY(-50%) scale(1.1);
}

.ai-carousel-nav-prev-{{ ai_gen_id }} {
  left: 20px;
}

.ai-carousel-nav-next-{{ ai_gen_id }} {
  right: 20px;
}

.ai-carousel-nav-{{ ai_gen_id }} svg {
  width: 24px;
  height: 24px;
}

/* Dots */
.ai-carousel-dots-{{ ai_gen_id }} {
  position: absolute;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 10px;
  z-index: 3;
}

.ai-carousel-dot-{{ ai_gen_id }} {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background-color: {{ block.settings.dot_color }};
  opacity: 0.5;
  border: none;
  cursor: pointer;
  transition: all 0.3s ease;
}

.ai-carousel-dot-{{ ai_gen_id }}.active {
  opacity: 1;
  width: 30px;
  border-radius: 5px;
}

/* Mensajes Desktop */
.ai-carousel-message-desktop-{{ ai_gen_id }} {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  width: 90%;
  max-width: 1000px;
  text-align: center;
  z-index: 4;
  bottom: {{ block.settings.message_position_desktop }}px;
  pointer-events: none;
}

.ai-carousel-message-desktop-{{ ai_gen_id }} h2 {
  margin: 0;
  font-weight: 700;
  line-height: 1.1;
  color: {{ block.settings.message_color_desktop }};
  font-size: {{ block.settings.message_size_desktop }}px;
}

/* Mensajes Mobile */
.ai-carousel-message-mobile-{{ ai_gen_id }} {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  width: 92%;
  max-width: 92%;
  text-align: center;
  z-index: 4;
  bottom: {{ block.settings.message_position_mobile }}px;
  pointer-events: none;
  display: none;
}

.ai-carousel-message-mobile-{{ ai_gen_id }} h2 {
  margin: 0;
  font-weight: 700;
  line-height: 1.15;
  color: {{ block.settings.message_color_mobile }};
  font-size: {{ block.settings.message_size_mobile }}px;
}

/* Breakpoint Mobile */
@media screen and (max-width: 749px) {
  .ai-carousel-container-{{ ai_gen_id }} {
    height: {{ block.settings.banner_height_mobile }}px !important;
  }

  .ai-carousel-message-desktop-{{ ai_gen_id }} {
    display: none;
  }

  .ai-carousel-message-mobile-{{ ai_gen_id }} {
    display: block;
  }
}
{% endstyle %}

<carousel-banner-{{ ai_gen_id }}
  class="ai-carousel-banner-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-interval="{{ block.settings.autoplay_interval }}"
>
  <div class="ai-carousel-container-{{ ai_gen_id }}">
    <div class="ai-carousel-track-{{ ai_gen_id }}">
      {% assign has_images = false %}
      {% for i in (1..5) %}
        {% assign image_key = 'image_' | append:i %}
        {% if block.settings[image_key] != blank %}
          {% assign has_images = true %}
          {% break %}
        {% endif %}
      {% endfor %}

      {% if has_images %}
        {% for i in (1..5) %}
          {% assign image_key = 'image_' | append:i %}
          {% assign title_key = 'title_' | append:i %}
          {% assign description_key = 'description_' | append:i %}
          {% assign image = block.settings[image_key] %}
          {% assign title = block.settings[title_key] %}
          {% assign description = block.settings[description_key] %}
          {% if image != blank %}
            <div class="ai-carousel-slide-{{ ai_gen_id }}" data-slide="{{ i }}">
              <img src="{{ image | image_url: width:2000 }}" alt="Slide {{ i }}">
              {% if block.settings.show_overlay %}
                <div class="ai-carousel-overlay-{{ ai_gen_id }}"></div>
              {% endif %}
              {% if title != blank or description != blank %}
                <div class="ai-carousel-content-{{ ai_gen_id }}">
                  {% if title != blank %}<h2 class="ai-carousel-title-{{ ai_gen_id }}">{{ title }}</h2>{% endif %}
                  {% if description != blank %}<p class="ai-carousel-description-{{ ai_gen_id }}">{{ description }}</p>{% endif %}
                </div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      {% else %}
        <div class="ai-carousel-slide-{{ ai_gen_id }}">
          <div class="ai-carousel-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-carousel-empty-state-{{ ai_gen_id }}">Agrega imágenes para comenzar</div>
          </div>
        </div>
      {% endif %}
    </div>

    {% if has_images and block.settings.show_navigation %}
      <button class="ai-carousel-nav-prev-{{ ai_gen_id }} ai-carousel-nav-{{ ai_gen_id }}" aria-label="Anterior">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <button class="ai-carousel-nav-next-{{ ai_gen_id }} ai-carousel-nav-{{ ai_gen_id }}" aria-label="Siguiente">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    {% endif %}

    {% if has_images and block.settings.show_dots %}
      <div class="ai-carousel-dots-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% assign image_key = 'image_' | append:i %}
          {% assign image = block.settings[image_key] %}
          {% if image != blank %}
            <button class="ai-carousel-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-slide="{{ forloop.index0 }}" aria-label="Ir a la diapositiva {{ i }}"></button>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    <div class="ai-carousel-message-desktop-{{ ai_gen_id }}">
      {% if block.settings.message_text_desktop != blank %}
        <h2>{{ block.settings.message_text_desktop }}</h2>
      {% endif %}
    </div>
    <div class="ai-carousel-message-mobile-{{ ai_gen_id }}">
      {% if block.settings.message_text_mobile != blank %}
        <h2>{{ block.settings.message_text_mobile }}</h2>
      {% endif %}
    </div>

  </div>
</carousel-banner-{{ ai_gen_id }}>

<script>
(function(){
  class CarouselBanner{{ ai_gen_id }} extends HTMLElement {
    constructor(){ super(); this.currentSlide=0; this.autoplayInterval=null; }
    connectedCallback(){
      this.track=this.querySelector('.ai-carousel-track-{{ ai_gen_id }}');
      this.slides=this.querySelectorAll('.ai-carousel-slide-{{ ai_gen_id }}');
      this.dots=this.querySelectorAll('.ai-carousel-dot-{{ ai_gen_id }}');
      this.prev=this.querySelector('.ai-carousel-nav-prev-{{ ai_gen_id }}');
      this.next=this.querySelector('.ai-carousel-nav-next-{{ ai_gen_id }}');
      this.autoplay=this.dataset.autoplay==='true';
      this.interval=parseInt(this.dataset.interval)*1000;
      if(this.slides.length<=1) return;
      this.prev?.addEventListener('click',()=>{ this.goTo(this.currentSlide-1); this.resetAutoplay(); });
      this.next?.addEventListener('click',()=>{ this.goTo(this.currentSlide+1); this.resetAutoplay(); });
      this.dots.forEach((dot,i)=>{ dot.addEventListener('click',()=>{ this.goTo(i); this.resetAutoplay(); }); });
      if(this.autoplay) this.startAutoplay();
      this.addEventListener('mouseenter',()=>{ if(this.autoplay) this.stopAutoplay(); });
      this.addEventListener('mouseleave',()=>{ if(this.autoplay) this.startAutoplay(); });
    }
    goTo(index){
      if(index<0) index=this.slides.length-1; else if(index>=this.slides.length) index=0;
      this.currentSlide=index;
      this.track.style.transform=`translateX(-${index*100}%)`;
      this.dots.forEach((dot,i)=>dot.classList.toggle('active', i===index));
    }
    startAutoplay(){ this.autoplayInterval=setInterval(()=>{ this.goTo(this.currentSlide+1); }, this.interval); }
    stopAutoplay(){ clearInterval(this.autoplayInterval); }
    resetAutoplay(){ if(this.autoplay){ this.stopAutoplay(); this.startAutoplay(); } }
  }
  customElements.define('carousel-banner-{{ ai_gen_id }}', CarouselBanner{{ ai_gen_id }});
})();
</script>

{% schema %}
{
  "name": "Banner carrusel completo",
  "settings": [
    /* ===== Mensaje Desktop ===== */
    { "type":"text",  "id":"message_text_desktop",     "label":"Mensaje (Desktop)", "default":"INFORMACIÓN" },
    { "type":"range", "id":"message_position_desktop", "label":"Posición vertical (Desktop)", "min":0, "max":400, "step":5, "default":60 },
    { "type":"range", "id":"message_size_desktop",     "label":"Tamaño del mensaje (Desktop)", "min":20, "max":120, "step":2, "default":72 },
    { "type":"color", "id":"message_color_desktop",    "label":"Color del mensaje (Desktop)", "default":"#FFFFFF" },

    /* ===== Mensaje Mobile ===== */
    { "type":"text",  "id":"message_text_mobile",      "label":"Mensaje (Mobile)", "default":"INFO" },
    { "type":"range", "id":"message_position_mobile",  "label":"Posición vertical (Mobile)", "min":0, "max":400, "step":5, "default":40 },
    { "type":"range", "id":"message_size_mobile",      "label":"Tamaño del mensaje (Mobile)", "min":16, "max":80,  "step":2, "default":36 },
    { "type":"color", "id":"message_color_mobile",     "label":"Color del mensaje (Mobile)", "default":"#FFFFFF" },

    /* ===== Altura Banner ===== */
    { "type":"range", "id":"banner_height_desktop","label":"Altura del banner (Desktop)","min":300,"max":1000,"step":10,"unit":"px","default":500 },
    { "type":"range", "id":"banner_height_mobile", "label":"Altura del banner (Mobile)","min":200,"max":800, "step":10,"unit":"px","default":360 },

    /* ===== Visual generales ===== */
    { "type":"range","id":"border_radius","label":"Radio del borde","min":0,"max":40,"step":2,"unit":"px","default":0 },
    { "type":"color","id":"background_color","label":"Color de fondo","default":"#000000" },

    /* ===== Slides ===== */
    {"type":"image_picker","id":"image_1","label":"Imagen 1"},
    {"type":"text","id":"title_1","label":"Título 1"},
    {"type":"textarea","id":"description_1","label":"Descripción 1"},

    {"type":"image_picker","id":"image_2","label":"Imagen 2"},
    {"type":"text","id":"title_2","label":"Título 2"},
    {"type":"textarea","id":"description_2","label":"Descripción 2"},

    {"type":"image_picker","id":"image_3","label":"Imagen 3"},
    {"type":"text","id":"title_3","label":"Título 3"},
    {"type":"textarea","id":"description_3","label":"Descripción 3"},

    {"type":"image_picker","id":"image_4","label":"Imagen 4"},
    {"type":"text","id":"title_4","label":"Título 4"},
    {"type":"textarea","id":"description_4","label":"Descripción 4"},

    {"type":"image_picker","id":"image_5","label":"Imagen 5"},
    {"type":"text","id":"title_5","label":"Título 5"},
    {"type":"textarea","id":"description_5","label":"Descripción 5"},

    { "type":"range","id":"title_size","label":"Tamaño del título por slide","min":20,"max":80,"step":2,"unit":"px","default":48 },
    { "type":"range","id":"description_size","label":"Tamaño de la descripción por slide","min":12,"max":32,"step":2,"unit":"px","default":18 },
    { "type":"color","id":"text_color","label":"Color del texto de slide","default":"#FFFFFF" },

    /* Overlay / nav / dots / autoplay */
    { "type":"range","id":"overlay_opacity","label":"Opacidad del overlay (%)","min":0,"max":100,"step":5,"default":50 },
    { "type":"checkbox","id":"show_overlay","label":"Mostrar overlay","default":true },
    { "type":"checkbox","id":"show_navigation","label":"Mostrar flechas","default":true },
    { "type":"checkbox","id":"show_dots","label":"Mostrar puntos","default":true },
    { "type":"checkbox","id":"autoplay","label":"Reproducción automática","default":true },
    { "type":"range","id":"autoplay_interval","label":"Intervalo autoplay (segundos)","min":2,"max":10,"step":1,"default":3 },
    { "type":"color","id":"nav_button_color","label":"Color fondo flechas","default":"rgba(0,0,0,0.3)" },
    { "type":"color","id":"nav_icon_color","label":"Color íconos flechas","default":"#fff" },
    { "type":"color","id":"dot_color","label":"Color puntos","default":"#fff" }
  ],
  "presets":[{"name":"Banner carrusel completo"}]
}
{% endschema %}