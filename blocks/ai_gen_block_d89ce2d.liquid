{% doc %}
  @prompt
    QUIERO UNA SECCION QUE HORIZONTALMENTE ESTE DIVIDA EN DOS LA PARTE DE LA IZQUIERDA QUE SEA PARA UNA IMAGEN QUE CONECTA A WHATSAPP A UN NUMERO EN PARTICULAR Y LA SEGUNDA LA DE LA DERECHA ES PARA UNA IMAGEN QUE CONECTA CON UN CORREO ELECTRONICO, QUIERO QUE PUEDA EDITAR LA POSICION EL TAMAÑO, LOS BORDES ETC  Y ADEMAS QUE ME PERMITA COLOCAR UNA IMAEGN ABAJO LARGA DOND EPUEDA COLOCAR MIS HORARIOS DE ATENCION , NINGUNA DE LAS DOS IMAGENES ME DIRIGE DONDE E DIJE YA QUE LA DE WHATSAPP DICE QUE EL APPI DE WHATSAPP BLOQUEO EL ACCESO Y LA OTRA NO ABRE EL CORREO  ADEMASUQIERO QUE EN LA VISTA MOBILE SE VEA IGUAL QUE EN LA DE ESCRITORIO DOS COLUMNAS DE IMAGENES Y UNA FNJA ABAJO PARA LA TERCERA IMAGEN, AUN NO ME DEJA HACERLO NO CARGA NI WHATSAPP NI EL CORREO
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-section-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-contact-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
  }

  .ai-contact-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: {{ block.settings.schedule_spacing }}px;
  }

  .ai-contact-item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.item_border_radius }}px;
    box-shadow: 0 {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
  }

  .ai-contact-link-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    height: 100%;
    text-decoration: none;
    cursor: pointer;
  }

  .ai-contact-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.item_height }}px;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .ai-contact-link-{{ ai_gen_id }}:hover .ai-contact-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-contact-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.item_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-contact-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-contact-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-contact-schedule-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.schedule_border_radius }}px;
    box-shadow: 0 {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
  }

  .ai-contact-schedule-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.schedule_height }}px;
    object-fit: cover;
    display: block;
  }

  .ai-contact-schedule-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.schedule_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-contact-schedule-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 150px;
  }

  @media screen and (max-width: 749px) {
    .ai-contact-image-{{ ai_gen_id }} {
      height: {{ block.settings.item_height_mobile }}px;
    }

    .ai-contact-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.item_height_mobile }}px;
    }

    .ai-contact-schedule-image-{{ ai_gen_id }} {
      height: {{ block.settings.schedule_height_mobile }}px;
    }

    .ai-contact-schedule-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.schedule_height_mobile }}px;
    }
  }
{% endstyle %}

<contact-links-{{ ai_gen_id }} class="ai-contact-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-container-{{ ai_gen_id }}">
    <div class="ai-contact-grid-{{ ai_gen_id }}">
      <div class="ai-contact-item-{{ ai_gen_id }}">
        {% if block.settings.whatsapp_number != blank %}
          <a
            href="#"
            class="ai-contact-link-{{ ai_gen_id }}"
            data-type="whatsapp"
            data-number="{{ block.settings.whatsapp_number }}"
            aria-label="Contactar por WhatsApp"
          >
            {% if block.settings.whatsapp_image %}
              <img
                src="{{ block.settings.whatsapp_image | image_url: width: 800 }}"
                alt="WhatsApp"
                loading="lazy"
                width="{{ block.settings.whatsapp_image.width }}"
                height="{{ block.settings.whatsapp_image.height }}"
                class="ai-contact-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-contact-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
                <div class="ai-contact-empty-state-{{ ai_gen_id }}">
                  Agregar imagen de WhatsApp
                </div>
              </div>
            {% endif %}
          </a>
        {% else %}
          {% if block.settings.whatsapp_image %}
            <img
              src="{{ block.settings.whatsapp_image | image_url: width: 800 }}"
              alt="WhatsApp"
              loading="lazy"
              width="{{ block.settings.whatsapp_image.width }}"
              height="{{ block.settings.whatsapp_image.height }}"
              class="ai-contact-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-contact-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-contact-empty-state-{{ ai_gen_id }}">
                Agregar imagen y número de WhatsApp
              </div>
            </div>
          {% endif %}
        {% endif %}
      </div>

      <div class="ai-contact-item-{{ ai_gen_id }}">
        {% if block.settings.email != blank %}
          <a
            href="#"
            class="ai-contact-link-{{ ai_gen_id }}"
            data-type="email"
            data-email="{{ block.settings.email }}"
            aria-label="Enviar correo electrónico"
          >
            {% if block.settings.email_image %}
              <img
                src="{{ block.settings.email_image | image_url: width: 800 }}"
                alt="Email"
                loading="lazy"
                width="{{ block.settings.email_image.width }}"
                height="{{ block.settings.email_image.height }}"
                class="ai-contact-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-contact-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
                <div class="ai-contact-empty-state-{{ ai_gen_id }}">
                  Agregar imagen de correo
                </div>
              </div>
            {% endif %}
          </a>
        {% else %}
          {% if block.settings.email_image %}
            <img
              src="{{ block.settings.email_image | image_url: width: 800 }}"
              alt="Email"
              loading="lazy"
              width="{{ block.settings.email_image.width }}"
              height="{{ block.settings.email_image.height }}"
              class="ai-contact-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-contact-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-contact-empty-state-{{ ai_gen_id }}">
                Agregar imagen y correo electrónico
              </div>
            </div>
          {% endif %}
        {% endif %}
      </div>
    </div>

    <div class="ai-contact-schedule-{{ ai_gen_id }}">
      {% if block.settings.schedule_image %}
        <img
          src="{{ block.settings.schedule_image | image_url: width: 1600 }}"
          alt="Horarios de atención"
          loading="lazy"
          width="{{ block.settings.schedule_image.width }}"
          height="{{ block.settings.schedule_image.height }}"
          class="ai-contact-schedule-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-contact-schedule-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-contact-empty-state-{{ ai_gen_id }}">
            Agregar imagen de horarios
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</contact-links-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactLinks{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.links = this.querySelectorAll('.ai-contact-link-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.links.forEach((link) => {
          link.addEventListener('click', (e) => {
            e.preventDefault();
            const type = link.getAttribute('data-type');
            
            if (type === 'whatsapp') {
              const number = link.getAttribute('data-number');
              if (number) {
                const cleanNumber = number.replace(/\D/g, '');
                window.open('https://wa.me/' + cleanNumber, '_blank');
              }
            } else if (type === 'email') {
              const email = link.getAttribute('data-email');
              if (email) {
                window.location.href = 'mailto:' + email;
              }
            }
          });
        });
      }
    }

    customElements.define('contact-links-{{ ai_gen_id }}', ContactLinks{{ ai_gen_id }});
  })();
</script>

