{% doc %}
  @prompt
    necesito una seccion de texto que este centrada en la pagina, que no ocupe la totalidad del ancho de la pagina que me permita usar los diferentes tipos de letras que vienen en shopif, quiero que permitas usar el interlineado pero que pueda ser menor que 1.0 y ademas que me permitas editar las letras de todas las formas 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-block-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-text-block-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_width }}px;
    width: 100%;
  }

  .ai-text-block-content-{{ ai_gen_id }} {
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-style: {{ block.settings.text_font.style }};
    font-size: {{ block.settings.font_size }}px;
    line-height: {{ block.settings.line_height }};
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
    word-spacing: {{ block.settings.word_spacing }}px;
    {% if block.settings.text_transform != 'none' %}
      text-transform: {{ block.settings.text_transform }};
    {% endif %}
    {% if block.settings.text_decoration != 'none' %}
      text-decoration: {{ block.settings.text_decoration }};
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-text-block-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px 16px {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }

    .ai-text-block-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-text-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-block-container-{{ ai_gen_id }}">
    {% if block.settings.text != blank %}
      <div class="ai-text-block-content-{{ ai_gen_id }}">
        {{ block.settings.text }}
      </div>
    {% else %}
      <div class="ai-text-block-content-{{ ai_gen_id }}">
        <p>Agrega tu texto aquí. Puedes personalizar la fuente, el tamaño, el interlineado y más desde la configuración del bloque.</p>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Texto personalizable",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto"
    },
    {
      "type": "header",
      "content": "Diseño"
    },
    {
      "type": "range",
      "id": "content_width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Ancho del contenido",
      "default": 800
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alineación del texto",
      "options": [
        {
          "value": "left",
          "label": "Izquierda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Derecha"
        },
        {
          "value": "justify",
          "label": "Justificado"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Espaciado superior",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Espaciado inferior",
      "default": 40
    },
    {
      "type": "header",
      "content": "Tipografía"
    },
    {
      "type": "font_picker",
      "id": "text_font",
      "label": "Fuente",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Tamaño de fuente",
      "default": 16
    },
    {
      "type": "range",
      "id": "line_height",
      "min": 0.5,
      "max": 3,
      "step": 0.1,
      "label": "Interlineado",
      "default": 1.5
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "min": -2,
      "max": 10,
      "step": 0.5,
      "unit": "px",
      "label": "Espaciado entre letras",
      "default": 0
    },
    {
      "type": "range",
      "id": "word_spacing",
      "min": -5,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Espaciado entre palabras",
      "default": 0
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Transformación de texto",
      "options": [
        {
          "value": "none",
          "label": "Normal"
        },
        {
          "value": "uppercase",
          "label": "Mayúsculas"
        },
        {
          "value": "lowercase",
          "label": "Minúsculas"
        },
        {
          "value": "capitalize",
          "label": "Capitalizar"
        }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "text_decoration",
      "label": "Decoración de texto",
      "options": [
        {
          "value": "none",
          "label": "Ninguna"
        },
        {
          "value": "underline",
          "label": "Subrayado"
        },
        {
          "value": "line-through",
          "label": "Tachado"
        },
        {
          "value": "overline",
          "label": "Línea superior"
        }
      ],
      "default": "none"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#121212"
    }
  ],
  "presets": [
    {
      "name": "Texto personalizable"
    }
  ]
}
{% endschema %}
