{% doc %}
  @prompt
    Large bold text filled with an image. Include a setting to control the background color., COMO PUEDO CAMBIAR LA POSICION DE LA IMAGEN QUE SALGA LO QUE YO QUIERA QUE SALGA, LA POSICION HORIZONTAL NO ESTA FUNCIONANDO Y ADEMAS QUIERO QUE EL TAMAÑO DE LA FUENTE SEA GRANDE , QUIERO PODER ESCALARLO EN MOBILE PORQUE SI AUMENTO EL TAMAÑO EN DESKTOP SE VE MAL EN MOBILE Y QUIERO TENER AUN MAYOR CONTROL EN EL  PADDING, esta muy bien podrias linkear esta seccion con instagram
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_horizontal }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-image-text-wrapper-{{ ai_gen_id }} {
    position: relative;
    display: inline-block;
  }

  .ai-image-text-link-{{ ai_gen_id }} {
    text-decoration: none;
    display: inline-block;
  }

  .ai-image-text-content-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size_desktop }}px;
    font-weight: 700;
    line-height: 1.1;
    margin: 0;
    background-image: url('{{ block.settings.fill_image | image_url: width: 2000 }}');
    background-size: {{ block.settings.image_scale }}%;
    background-position: {{ block.settings.image_position_x }}% {{ block.settings.image_position_y }}%;
    background-repeat: no-repeat;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    transition: transform 0.3s ease;
  }

  .ai-image-text-link-{{ ai_gen_id }}:hover .ai-image-text-content-{{ ai_gen_id }} {
    transform: scale(1.02);
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size_desktop }}px;
    font-weight: 700;
    line-height: 1.1;
    margin: 0;
    color: #cccccc;
  }

  @media screen and (min-width: 750px) {
    .ai-image-text-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width_percent }}%;
      max-width: 100%;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px {{ block.settings.padding_horizontal_mobile }}px;
    }

    .ai-image-text-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size_mobile }}px;
    }

    .ai-image-text-placeholder-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size_mobile }}px;
    }
  }
{% endstyle %}

<image-filled-text-{{ ai_gen_id }}
  class="ai-image-text-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-text-wrapper-{{ ai_gen_id }}">
    {% if block.settings.link != blank %}
      <a href="{{ block.settings.link }}" class="ai-image-text-link-{{ ai_gen_id }}">
        {% if block.settings.fill_image %}
          <h2 class="ai-image-text-content-{{ ai_gen_id }}">
            {{ block.settings.text }}
          </h2>
        {% else %}
          <h2 class="ai-image-text-placeholder-{{ ai_gen_id }}">
            {{ block.settings.text }}
          </h2>
        {% endif %}
      </a>
    {% else %}
      {% if block.settings.fill_image %}
        <h2 class="ai-image-text-content-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </h2>
      {% else %}
        <h2 class="ai-image-text-placeholder-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </h2>
      {% endif %}
    {% endif %}
  </div>
</image-filled-text-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Texto con imagen",
  "settings": [
    {
      "type": "header",
      "content": "Texto"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Texto",
      "default": "TEXTO BOLD"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Enlace"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alineación",
      "options": [
        {
          "value": "left",
          "label": "Izquierda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Derecha"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Tamaño de fuente"
    },
    {
      "type": "range",
      "id": "font_size_desktop",
      "label": "Tamaño en escritorio",
      "min": 50,
      "max": 400,
      "step": 10,
      "unit": "px",
      "default": 150
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Tamaño en móvil",
      "min": 30,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Imagen de relleno"
    },
    {
      "type": "image_picker",
      "id": "fill_image",
      "label": "Imagen"
    },
    {
      "type": "range",
      "id": "image_scale",
      "label": "Escala de imagen",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "image_position_x",
      "label": "Posición horizontal",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "image_position_y",
      "label": "Posición vertical",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "header",
      "content": "Espaciado escritorio"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espaciado superior",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espaciado inferior",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Espaciado lateral",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Espaciado móvil"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Espaciado superior",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Espaciado inferior",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_horizontal_mobile",
      "label": "Espaciado lateral",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Estilo"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Ancho en escritorio",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Texto con imagen"
    }
  ]
}
{% endschema %}
