{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
/* WRAPPER */
.ai-new-in-grid-{{ ai_gen_id }} {
  width: 100%;
  margin: 0;
  padding: 0;
}

/* HEADER */
.ai-new-in-grid__header-{{ ai_gen_id }} {
  padding: 20px 0 16px;
}

.ai-new-in-grid__heading-{{ ai_gen_id }} {
  font-size: {{ block.settings.heading_size }}px;
  font-weight: 600;
  margin: 0;
  margin-left: {{ block.settings.heading_left_margin }}px;
  color: {{ block.settings.heading_color }};
}

/* GRID DE PRODUCTOS CON PADDING HORIZONTAL MÍNIMO */
.ai-new-in-grid__products-{{ ai_gen_id }} {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  padding: 0 8px;
}

@media screen and (max-width: 749px) {
  .ai-new-in-grid__products-{{ ai_gen_id }} {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    padding: 0 8px;
  }
}

/* CARD */
.ai-new-in-grid__product-card-{{ ai_gen_id }} {
  overflow: hidden;
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* LINK */
.ai-new-in-grid__link-{{ ai_gen_id }} {
  display: flex;
  flex-direction: column;
  height: 100%;
  text-decoration: none;
}

/* IMAGE WRAPPER */
.ai-new-in-grid__image-wrapper-{{ ai_gen_id }} {
  position: relative;
  width: 100%;
  overflow: hidden;
  background-color: #f6f6f6;
  aspect-ratio: {% if block.settings.image_ratio == 'square' %}1 / 1{% else %}3 / 4{% endif %};
  flex-shrink: 0;
}

/* SLIDER INTERNO DE IMÁGENES */
.ai-new-in-grid__image-slider-{{ ai_gen_id }} {
  display: flex;
  width: 100%;
  height: 100%;
  overflow-x: auto;
  overflow-y: hidden;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
}

/* OCULTAR SCROLLBAR NATIVO */
.ai-new-in-grid__image-slider-{{ ai_gen_id }}::-webkit-scrollbar {
  display: none;
}

.ai-new-in-grid__image-slider-{{ ai_gen_id }} {
  -ms-overflow-style: none;
  scrollbar-width: none;
}

/* IMAGEN */
.ai-new-in-grid__image-slider-{{ ai_gen_id }} img {
  flex: 0 0 100%;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  scroll-snap-align: start;
  transition: transform 0.4s ease;
}

/* HOVER ZOOM - SOLO EN DESKTOP */
@media screen and (min-width: 750px) {
  .ai-new-in-grid__image-slider-{{ ai_gen_id }} img:hover {
    transform: scale({{ block.settings.zoom_level | divided_by: 10.0 }});
  }
}

/* OVERLAY TITLE */
.ai-new-in-grid__image-title-{{ ai_gen_id }} {
  position: absolute;
  top: {{ block.settings.overlay_title_top }}px;
  left: {{ block.settings.overlay_title_left }}px;
  padding: {{ block.settings.overlay_title_padding }}px;
  font-size: {{ block.settings.overlay_title_size }}px;
  font-weight: 600;
  color: {{ block.settings.overlay_title_text_color }};
  background-color: {{ block.settings.overlay_title_bg_color }};
  opacity: {{ block.settings.overlay_title_opacity | divided_by: 100.0 }};
  border-radius: {{ block.settings.overlay_title_radius }}px;
  pointer-events: none;
  z-index: 2;
}

/* INDICATORS DE IMÁGENES - DISEÑO ULTRA MINIMALISTA */
.ai-new-in-grid__image-indicators-{{ ai_gen_id }} {
  display: none;
  justify-content: center;
  align-items: center;
  gap: 6px;
  padding: 8px;
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
}

@media screen and (max-width: 749px) {
  .ai-new-in-grid__image-indicators-{{ ai_gen_id }} {
    display: flex;
  }
}

.ai-new-in-grid__image-indicator-{{ ai_gen_id }} {
  width: 6px;
  height: 3px;
  border-radius: 2px;
  background-color: rgba(255, 255, 255, 0.5);
  cursor: pointer;
  transition: all 0.3s ease;
  border: none;
  padding: 0;
  appearance: none;
}

.ai-new-in-grid__image-indicator-{{ ai_gen_id }}:hover {
  background-color: rgba(255, 255, 255, 0.8);
}

.ai-new-in-grid__image-indicator-{{ ai_gen_id }}.active {
  background-color: rgba(255, 255, 255, 1);
  width: 12px;
}

/* INFO - CONTAINER FLEX PARA ALINEACIÓN */
.ai-new-in-grid__info-{{ ai_gen_id }} {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  flex-grow: 1;
  text-align: left;
  padding: 12px 8px;
  min-height: 80px;
}

/* TÍTULO CON ALTURA FIJA Y MARGEN IZQUIERDO CONTROLABLE */
.ai-new-in-grid__title-{{ ai_gen_id }} {
  font-size: 14px;
  font-weight: 500;
  margin-bottom: 0;
  margin-left: {{ block.settings.title_left_margin }}px;
  height: 40px;
  display: flex;
  align-items: center;
  color: {{ block.settings.text_color }};
  flex-shrink: 0;
  line-height: 1.3;
}

/* PRECIO SIEMPRE AL FONDO */
.ai-new-in-grid__price-{{ ai_gen_id }} {
  font-size: 14px;
  font-weight: 500;
  color: {{ block.settings.price_color }};
  margin-top: auto;
  margin-left: {{ block.settings.title_left_margin }}px;
  padding-top: 8px;
  border-top: 1px solid #f0f0f0;
}

/* EMPTY STATE */
.ai-new-in-grid__empty-state-{{ ai_gen_id }} {
  padding: 60px 20px;
  text-align: center;
  background: #f9f9f9;
  color: #666;
}

/* SINGLE IMAGE */
.ai-new-in-grid__single-image-{{ ai_gen_id }} {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  transition: transform 0.4s ease;
}

@media screen and (min-width: 750px) {
  .ai-new-in-grid__single-image-{{ ai_gen_id }}:hover {
    transform: scale({{ block.settings.zoom_level | divided_by: 10.0 }});
  }
}
{% endstyle %}

<new-in-grid-{{ ai_gen_id }} class="ai-new-in-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>

  {% if block.settings.heading != blank %}
    <div class="ai-new-in-grid__header-{{ ai_gen_id }}">
      <h2 class="ai-new-in-grid__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    </div>
  {% endif %}

  {% assign has_products = false %}
  {% for i in (1..8) %}
    {% assign product_key = 'product_' | append: i %}
    {% if block.settings[product_key] %}
      {% assign product = block.settings[product_key] %}
      {% if product.images.size > 0 %}
        {% assign has_products = true %}
        {% break %}
      {% endif %}
    {% endif %}
  {% endfor %}

  {% if has_products %}
    <div class="ai-new-in-grid__products-{{ ai_gen_id }}">
      {% for i in (1..8) %}
        {% assign product_key = 'product_' | append: i %}
        {% assign product = block.settings[product_key] %}
        
        {% if product and product.images.size > 0 %}
          <div class="ai-new-in-grid__product-card-{{ ai_gen_id }}">
            <a href="{{ product.url }}" aria-label="Ver {{ product.title | escape }}" class="ai-new-in-grid__link-{{ ai_gen_id }}">

              <div class="ai-new-in-grid__image-wrapper-{{ ai_gen_id }}">
                {% if block.settings.show_overlay_title and block.settings.overlay_title != blank %}
                  <div class="ai-new-in-grid__image-title-{{ ai_gen_id }}">
                    {{ block.settings.overlay_title }}
                  </div>
                {% endif %}

                {% assign images = product.images %}
                {% if images.size > 1 %}
                  <!-- SLIDER CON MÚLTIPLES IMÁGENES -->
                  <div class="ai-new-in-grid__image-slider-{{ ai_gen_id }}" data-slider-id="slider-{{ ai_gen_id }}-{{ i }}" data-product-index="{{ i }}">
                    {% for img in images %}
                      <img 
                        src="{{ img | image_url: width: 900 }}"
                        alt="{{ img.alt | escape }}"
                        loading="lazy"
                        width="900"
                        height="1200"
                      >
                    {% endfor %}
                  </div>

                  <!-- INDICADORES DE IMÁGENES -->
                  <div class="ai-new-in-grid__image-indicators-{{ ai_gen_id }}" data-indicators-id="indicators-{{ ai_gen_id }}-{{ i }}">
                    {% for img in images %}
                      <button type="button" class="ai-new-in-grid__image-indicator-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-image-index="{{ forloop.index0 }}" aria-label="Ver imagen {{ forloop.index }}"></button>
                    {% endfor %}
                  </div>
                {% elsif images.size == 1 %}
                  <!-- IMAGEN ÚNICA -->
                  <img 
                    src="{{ images[0] | image_url: width: 900 }}"
                    alt="{{ images[0].alt | escape }}"
                    loading="lazy"
                    width="900"
                    height="1200"
                    class="ai-new-in-grid__single-image-{{ ai_gen_id }}"
                  >
                {% endif %}
              </div>

              <div class="ai-new-in-grid__info-{{ ai_gen_id }}">
                <div class="ai-new-in-grid__title-{{ ai_gen_id }}">
                  {{ product.title }}
                </div>
                <div class="ai-new-in-grid__price-{{ ai_gen_id }}">
                  {{ product.price_min | money_with_currency }}
                </div>
              </div>

            </a>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% else %}
    <div class="ai-new-in-grid__empty-state-{{ ai_gen_id }}">
      Selecciona productos con imágenes para mostrar en el grid.
    </div>
  {% endif %}

</new-in-grid-{{ ai_gen_id }}>

<script>
  (function() {
    const genId = '{{ ai_gen_id }}';
    
    // Inicializar sliders con swipe en mobile
    document.querySelectorAll('[data-slider-id^="slider-{{ ai_gen_id }}-"]').forEach(slider => {
      let startX = 0;
      let currentScroll = 0;
      let isScrolling = false;
      let isDragging = false;
      let velocity = 0;
      let lastX = 0;
      let lastTime = 0;
      let isMobile = window.innerWidth < 750;

      // Detectar redimensionamiento
      window.addEventListener('resize', () => {
        isMobile = window.innerWidth < 750;
      });

      // Touch events para swipe
      slider.addEventListener('touchstart', (e) => {
        startX = e.touches[0].clientX;
        currentScroll = slider.scrollLeft;
        isScrolling = true;
        isDragging = true;
        lastX = startX;
        lastTime = Date.now();
        slider.style.scrollBehavior = 'auto';
      }, { passive: true });

      slider.addEventListener('touchmove', (e) => {
        if (!isScrolling) return;
        
        const x = e.touches[0].clientX;
        const walk = (startX - x);
        const now = Date.now();
        const timeDelta = now - lastTime;
        
        if (timeDelta > 0) {
          velocity = (x - lastX) / timeDelta;
        }
        
        lastX = x;
        lastTime = now;
        slider.scrollLeft = currentScroll + walk;
        actualizarIndicadores(slider);
      }, { passive: true });

      slider.addEventListener('touchend', () => {
        isScrolling = false;
        isDragging = false;
        slider.style.scrollBehavior = 'smooth';
        
        // Aplicar velocidad de swipe
        const itemWidth = slider.clientWidth;
        const currentIndex = Math.round(slider.scrollLeft / itemWidth);
        
        if (Math.abs(velocity) > 0.3) {
          const direction = velocity > 0 ? -1 : 1;
          const newIndex = Math.max(0, Math.min(
            Math.ceil(slider.scrollWidth / itemWidth) - 1,
            currentIndex + direction
          ));
          slider.scrollLeft = newIndex * itemWidth;
        } else {
          slider.scrollLeft = currentIndex * itemWidth;
        }
        
        setTimeout(() => actualizarIndicadores(slider), 300);
      }, { passive: true });

      // Detectar scroll para actualizar indicadores
      slider.addEventListener('scroll', () => {
        if (!isDragging) {
          actualizarIndicadores(slider);
        }
      }, { passive: true });

      // Actualizar indicadores al cargar
      setTimeout(() => actualizarIndicadores(slider), 100);
    });

    // Función para actualizar indicadores
    function actualizarIndicadores(slider) {
      const sliderId = slider.getAttribute('data-slider-id');
      const indicatorsContainer = document.querySelector('[data-indicators-id="' + sliderId.replace('slider-', 'indicators-') + '"]');
      
      if (!indicatorsContainer) return;

      const indicators = indicatorsContainer.querySelectorAll('.ai-new-in-grid__image-indicator-' + genId);
      const scrollLeft = slider.scrollLeft;
      const itemWidth = slider.clientWidth;
      
      // Calcular índice actual
      const currentIndex = Math.round(scrollLeft / itemWidth);
      
      indicators.forEach((indicator, index) => {
        indicator.classList.toggle('active', index === currentIndex);
      });
    }

    // Hacer indicadores clickeables
    document.querySelectorAll('[data-indicators-id^="indicators-{{ ai_gen_id }}-"]').forEach(indicatorsContainer => {
      const indicators = indicatorsContainer.querySelectorAll('.ai-new-in-grid__image-indicator-' + genId);
      const sliderId = indicatorsContainer.getAttribute('data-indicators-id').replace('indicators-', 'slider-');
      const slider = document.querySelector('[data-slider-id="' + sliderId + '"]');

      if (!slider) return;

      indicators.forEach((indicator) => {
        indicator.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          
          const imageIndex = parseInt(indicator.getAttribute('data-image-index'));
          const scrollPosition = imageIndex * slider.clientWidth;
          
          slider.style.scrollBehavior = 'smooth';
          slider.scrollLeft = scrollPosition;
          
          setTimeout(() => actualizarIndicadores(slider), 300);
        });
      });
    });

    // Prevenir que los indicadores causen navegación del link
    document.querySelectorAll('.ai-new-in-grid__image-indicator-' + genId).forEach(indicator => {
      indicator.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        return false;
      });
    });
  })();
</script>

{% schema %}
{
  "name": "New in grid slider",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título del bloque" },
    { "type": "range", "id": "heading_size", "label": "Tamaño del título", "min": 16, "max": 48, "step": 2, "default": 28 },
    { "type": "color", "id": "heading_color", "label": "Color del título", "default": "#121212" },
    { "type": "range", "id": "heading_left_margin", "label": "Margen izquierdo del título del bloque", "min": 0, "max": 40, "step": 2, "default": 0 },
    
    { "type": "checkbox", "id": "show_overlay_title", "label": "Mostrar título sobre imagen", "default": true },
    { "type": "text", "id": "overlay_title", "label": "Texto del título sobre imagen", "default": "NEW IN" },
    { "type": "range", "id": "overlay_title_size", "label": "Tamaño del texto sobre imagen", "min": 10, "max": 32, "step": 2, "default": 14 },
    { "type": "color", "id": "overlay_title_text_color", "label": "Color del texto sobre imagen", "default": "#ffffff" },
    { "type": "color", "id": "overlay_title_bg_color", "label": "Color de fondo del texto sobre imagen", "default": "#000000" },
    { "type": "range", "id": "overlay_title_opacity", "label": "Opacidad del texto sobre imagen", "min": 0, "max": 100, "step": 5, "default": 80 },
    { "type": "range", "id": "overlay_title_padding", "label": "Padding del texto sobre imagen", "min": 4, "max": 20, "step": 2, "default": 8 },
    { "type": "range", "id": "overlay_title_radius", "label": "Border radius del texto sobre imagen", "min": 0, "max": 20, "step": 2, "default": 4 },
    { "type": "range", "id": "overlay_title_top", "label": "Top del texto sobre imagen", "min": 0, "max": 40, "step": 2, "default": 12 },
    { "type": "range", "id": "overlay_title_left", "label": "Left del texto sobre imagen", "min": 0, "max": 40, "step": 2, "default": 12 },
    
    { "type": "select", "id": "image_ratio", "label": "Proporción de imagen", "options": [
      { "value": "square", "label": "Cuadrada (1:1)" },
      { "value": "portrait", "label": "Vertical (3:4)" }
    ], "default": "portrait" },
    
    { "type": "range", "id": "zoom_level", "label": "Nivel de zoom al pasar mouse", "min": 10, "max": 20, "step": 1, "default": 15 },
    
    { "type": "range", "id": "title_left_margin", "label": "Margen izquierdo del título y precio", "min": 0, "max": 20, "step": 1, "default": 0 },
    
    { "type": "product", "id": "product_1", "label": "Producto 1" },
    { "type": "product", "id": "product_2", "label": "Producto 2" },
    { "type": "product", "id": "product_3", "label": "Producto 3" },
    { "type": "product", "id": "product_4", "label": "Producto 4" },
    { "type": "product", "id": "product_5", "label": "Producto 5" },
    { "type": "product", "id": "product_6", "label": "Producto 6" },
    { "type": "product", "id": "product_7", "label": "Producto 7" },
    { "type": "product", "id": "product_8", "label": "Producto 8" },
    
    { "type": "color", "id": "text_color", "label": "Color del título del producto", "default": "#121212" },
    { "type": "color", "id": "price_color", "label": "Color del precio", "default": "#121212" }
  ],
  "presets": [
    { "name": "New in grid con slider interno" }
  ]
}
{% endschema %}