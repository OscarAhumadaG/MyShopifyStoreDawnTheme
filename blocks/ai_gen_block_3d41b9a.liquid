    {
      "type": "header",
      "content": "Tamaños de texto - Móvil"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Tamaño del título",
      "default": 28
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "min": 12,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Tamaño del texto",
