{% doc %}
  @prompt
    quieroun banner de imagen que me permita modificar como se ve en mobile y como se ve en desktop que me permita hacer diferentes movimientos y ediciones 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-responsive-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-responsive-banner__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: auto;
  }

  .ai-responsive-banner__desktop-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: auto;
  }

  .ai-responsive-banner__mobile-{{ ai_gen_id }} {
    display: none;
    width: 100%;
    height: auto;
  }

  .ai-responsive-banner__placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-responsive-banner__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-responsive-banner__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-responsive-banner__content-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.content_position_y_desktop }}%;
    left: {{ block.settings.content_position_x_desktop }}%;
    transform: translate(-50%, -50%);
    text-align: {{ block.settings.text_alignment_desktop }};
    max-width: {{ block.settings.content_max_width_desktop }}%;
    width: 100%;
    padding: 20px;
  }

  .ai-responsive-banner__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size_desktop }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.spacing_desktop }}px;
    font-weight: 700;
    line-height: 1.2;
  }

  .ai-responsive-banner__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size_desktop }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.spacing_desktop }}px;
    line-height: 1.5;
  }

  .ai-responsive-banner__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_desktop }}px {{ block.settings.button_padding_desktop | times: 2 }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size_desktop }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-responsive-banner__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-responsive-banner__desktop-{{ ai_gen_id }} {
      display: {% if block.settings.mobile_image %}none{% else %}block{% endif %};
    }

    .ai-responsive-banner__mobile-{{ ai_gen_id }} {
      display: {% if block.settings.mobile_image %}block{% else %}none{% endif %};
    }

    .ai-responsive-banner__placeholder-{{ ai_gen_id }} {
      min-height: 300px;
    }

    .ai-responsive-banner__content-{{ ai_gen_id }} {
      top: {{ block.settings.content_position_y_mobile }}%;
      left: {{ block.settings.content_position_x_mobile }}%;
      text-align: {{ block.settings.text_alignment_mobile }};
      max-width: {{ block.settings.content_max_width_mobile }}%;
      padding: 15px;
    }

    .ai-responsive-banner__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      margin: 0 0 {{ block.settings.spacing_mobile }}px;
    }

    .ai-responsive-banner__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
      margin: 0 0 {{ block.settings.spacing_mobile }}px;
    }

    .ai-responsive-banner__button-{{ ai_gen_id }} {
      padding: {{ block.settings.button_padding_mobile }}px {{ block.settings.button_padding_mobile | times: 2 }}px;
      font-size: {{ block.settings.button_text_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-responsive-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-responsive-banner__image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.desktop_image %}
      <img
        src="{{ block.settings.desktop_image | image_url: width: 2000 }}"
        alt="{{ block.settings.desktop_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.desktop_image.width }}"
        height="{{ block.settings.desktop_image.height }}"
        class="ai-responsive-banner__desktop-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-responsive-banner__placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-responsive-banner__empty-state-{{ ai_gen_id }}">
          Add a desktop image to get started
        </div>
      </div>
    {% endif %}

    {% if block.settings.mobile_image %}
      <img
        src="{{ block.settings.mobile_image | image_url: width: 1000 }}"
        alt="{{ block.settings.mobile_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.mobile_image.width }}"
        height="{{ block.settings.mobile_image.height }}"
        class="ai-responsive-banner__mobile-{{ ai_gen_id }}"
      >
    {% endif %}

    {% if block.settings.show_content %}
      <div class="ai-responsive-banner__content-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-responsive-banner__heading-{{ ai_gen_id }}">
            {{ block.settings.heading }}
          </h2>
        {% endif %}

        {% if block.settings.text != blank %}
          <div class="ai-responsive-banner__text-{{ ai_gen_id }}">
            {{ block.settings.text }}
          </div>
        {% endif %}

        {% if block.settings.button_text != blank and block.settings.button_link != blank %}
          <a
            href="{{ block.settings.button_link }}"
            class="ai-responsive-banner__button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Banner responsive",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Imágenes"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Imagen de escritorio"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Imagen móvil"
    },
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "checkbox",
      "id": "show_content",
      "label": "Mostrar contenido",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Título",
      "default": "Banner de imagen"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto",
      "default": "<p>Agrega tu mensaje aquí</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del botón",
      "default": "Comprar ahora"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace del botón"
    },
    {
      "type": "header",
      "content": "Colores del contenido"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color del título",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Fondo del botón",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Texto del botón",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Fondo del botón (hover)",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Texto del botón (hover)",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Posición del contenido - Escritorio"
    },
    {
      "type": "range",
      "id": "content_position_x_desktop",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Posición horizontal",
      "default": 50
    },
    {
      "type": "range",
      "id": "content_position_y_desktop",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Posición vertical",
      "default": 50
    },
    {
      "type": "select",
      "id": "text_alignment_desktop",
      "label": "Alineación del texto",
      "options": [
        {
          "value": "left",
          "label": "Izquierda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Derecha"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "content_max_width_desktop",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Ancho máximo del contenido",
      "default": 50
    },
    {
      "type": "header",
      "content": "Tamaños de texto - Escritorio"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Tamaño del título",
      "default": 48
    },
    {
      "type": "range",
      "id": "text_size_desktop",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Tamaño del texto",
      "default": 18
    },
    {
      "type": "range",
      "id": "button_text_size_desktop",
      "min": 12,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Tamaño del texto del botón",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_padding_desktop",
      "min": 8,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Padding del botón",
      "default": 14
    },
    {
      "type": "range",
      "id": "spacing_desktop",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Espaciado entre elementos",
      "default": 16
    },
    {
      "type": "header",
      "content": "Posición del contenido - Móvil"
    },
    {
      "type": "range",
      "id": "content_position_x_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Posición horizontal",
      "default": 50
    },
    {
      "type": "range",
      "id": "content_position_y_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Posición vertical",
      "default": 50
    },
    {
      "type": "select",
      "id": "text_alignment_mobile",
      "label": "Alineación del texto",
      "options": [
        {
          "value": "left",
          "label": "Izquierda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Derecha"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "content_max_width_mobile",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Ancho máximo del contenido",
      "default": 90
