{% doc %}
  @prompt
    quiero una banner que no se tan grande para colocar un titulo de las colleciones  pero voy a montar es una imagen y quiero que me permita editar el tamaño etc
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-collection-banner__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.banner_height }}px;
    overflow: hidden;
  }

  .ai-collection-banner__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ block.settings.image_position }};
  }

  .ai-collection-banner__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-collection-banner__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-collection-banner__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-collection-banner__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  .ai-collection-banner__content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: {{ block.settings.text_alignment }};
    width: 90%;
    max-width: 800px;
    z-index: 2;
  }

  .ai-collection-banner__title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 700;
    line-height: 1.2;
  }

  .ai-collection-banner__subtitle-{{ ai_gen_id }} {
    margin: 12px 0 0;
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.4;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-banner__image-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.banner_height_mobile }}px;
    }

    .ai-collection-banner__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-collection-banner__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-collection-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-banner__image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.image %}
      <img
        src="{{ block.settings.image | image_url: width: 2000 }}"
        alt="{{ block.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
        class="ai-collection-banner__image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-collection-banner__placeholder-{{ ai_gen_id }}">
        {{ 'collection-apparel-1' | placeholder_svg_tag }}
        <div class="ai-collection-banner__empty-state-{{ ai_gen_id }}">
          Agrega una imagen para el banner
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_overlay %}
      <div class="ai-collection-banner__overlay-{{ ai_gen_id }}"></div>
    {% endif %}

    <div class="ai-collection-banner__content-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h1 class="ai-collection-banner__title-{{ ai_gen_id }}">
          {{ block.settings.title }}
        </h1>
      {% endif %}

      {% if block.settings.subtitle != blank %}
        <div class="ai-collection-banner__subtitle-{{ ai_gen_id }}">
          {{ block.settings.subtitle }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Banner de colección",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Imagen"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Posición de la imagen",
      "options": [
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "top",
          "label": "Arriba"
        },
        {
          "value": "bottom",
          "label": "Abajo"
        },
        {
          "value": "left",
          "label": "Izquierda"
        },
        {
          "value": "right",
          "label": "Derecha"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "banner_height",
      "min": 100,
      "max": 600,
      "step": 20,
      "unit": "px",
      "label": "Altura del banner (escritorio)",
      "default": 300
    },
    {
      "type": "range",
      "id": "banner_height_mobile",
      "min": 100,
      "max": 400,
      "step": 20,
      "unit": "px",
      "label": "Altura del banner (móvil)",
      "default": 200
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Radio de borde",
      "default": 0
    },
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Título",
      "default": "Nuestras Colecciones"
    },
    {
      "type": "inline_richtext",
      "id": "subtitle",
      "label": "Subtítulo"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alineación del texto",
      "options": [
        {
          "value": "left",
          "label": "Izquierda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Derecha"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Tamaño del título",
      "default": 48
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Tamaño del subtítulo",
      "default": 18
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Superposición"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Mostrar superposición",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Color de superposición",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Opacidad de superposición",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Banner de colección"
    }
  ]
}
{% endschema %}
