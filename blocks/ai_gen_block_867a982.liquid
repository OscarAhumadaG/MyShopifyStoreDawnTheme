{% doc %}
  @prompt
    Necesito una sección que muestre los productos más comprados de la tienda en una sola fila horizontal que ocupe todo el ancho de la página, sin dividirse en varias filas, con opción para elegir cuántos productos mostrar; cada producto debe incluir imagen, nombre y precio, y permitir personalizar el color y grosor del borde, el tamaño y tipo de letra, el espaciado entre nombre, precio e imagen, además de ser totalmente responsiva y ofrecer la posibilidad de agregar un título editable para la sección., quiero poder seleccionar productos individualmente, Quiero que pueda editar el espaciado tambien del cmiezo del borde de la imagen y el borde de la seccion quiero todo eso se pueda editar y que el espacio que te mencione anterioremente enstre el nombre y el precio se pueda acortar mucho mas quiero que ocupe toda la pantalla, quiero que peuda editar el espacio entre el nombre y el precio totalmente y que el espacio superior e inferior del itutlo ambien poder editarlos completo quiero que sea completo en la pagina y que pueda ajustar de igual forma en mobiles, ahora quiero poder cambiar los tipos de letras y y ademas las caracteristicas como bold cursive etc, esta muy bien solo que yo pueda confiurar el ancho de la seccion tanto en desktop como en mobile 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-row-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-product-row-wrapper-{{ ai_gen_id }} {
    max-width: {{ block.settings.section_max_width }}px;
    margin: 0 auto;
  }

  .ai-product-row-title-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_margin_bottom }}px 0;
    padding: {{ block.settings.title_padding_top }}px 0 {{ block.settings.title_padding_bottom }}px 0;
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-style: {{ block.settings.title_font_style }};
    text-transform: {{ block.settings.title_text_transform }};
    text-decoration: {{ block.settings.title_text_decoration }};
  }

  .ai-product-row-container-{{ ai_gen_id }} {
    width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: {{ block.settings.scrollbar_color }} transparent;
  }

  .ai-product-row-container-{{ ai_gen_id }}::-webkit-scrollbar {
    height: 8px;
  }

  .ai-product-row-container-{{ ai_gen_id }}::-webkit-scrollbar-track {
    background: transparent;
  }

  .ai-product-row-container-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
    background-color: {{ block.settings.scrollbar_color }};
    border-radius: 4px;
  }

  .ai-product-row-list-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: nowrap;
    gap: {{ block.settings.product_gap }}px;
    padding: 0 {{ block.settings.section_horizontal_padding }}px;
    margin: 0;
    list-style: none;
  }

  .ai-product-row-item-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: {{ block.settings.product_width }}px;
    display: flex;
    flex-direction: column;
  }

  .ai-product-row-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .ai-product-row-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    border: {{ block.settings.image_border_thickness }}px solid {{ block.settings.image_border_color }};
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: {{ block.settings.image_margin_bottom }}px;
  }

  .ai-product-row-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-row-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.name_price_gap }}px;
  }

  .ai-product-row-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_font_size }}px;
    color: {{ block.settings.name_color }};
    margin: 0;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    font-family: {{ block.settings.name_font.family }}, {{ block.settings.name_font.fallback_families }};
    font-weight: {{ block.settings.name_font.weight }};
    font-style: {{ block.settings.name_font_style }};
    text-transform: {{ block.settings.name_text_transform }};
    text-decoration: {{ block.settings.name_text_decoration }};
  }

  .ai-product-row-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    color: {{ block.settings.price_color }};
    margin: 0;
    font-family: {{ block.settings.price_font.family }}, {{ block.settings.price_font.fallback_families }};
    font-weight: {{ block.settings.price_font.weight }};
    font-style: {{ block.settings.price_font_style }};
    text-transform: {{ block.settings.price_text_transform }};
    text-decoration: {{ block.settings.price_text_decoration }};
  }

  @media screen and (max-width: 749px) {
    .ai-product-row-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px 0 {{ block.settings.section_padding_bottom_mobile }}px 0;
    }

    .ai-product-row-wrapper-{{ ai_gen_id }} {
      max-width: {{ block.settings.section_max_width_mobile }}px;
    }

    .ai-product-row-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size_mobile }}px;
      margin-bottom: {{ block.settings.title_margin_bottom_mobile }}px;
      padding: {{ block.settings.title_padding_top_mobile }}px 0 {{ block.settings.title_padding_bottom_mobile }}px 0;
    }

    .ai-product-row-list-{{ ai_gen_id }} {
      gap: {{ block.settings.product_gap_mobile }}px;
      padding: 0 {{ block.settings.section_horizontal_padding_mobile }}px;
    }

    .ai-product-row-item-{{ ai_gen_id }} {
      width: {{ block.settings.product_width_mobile }}px;
    }

    .ai-product-row-image-wrapper-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.image_margin_bottom_mobile }}px;
    }

    .ai-product-row-info-{{ ai_gen_id }} {
      gap: {{ block.settings.name_price_gap_mobile }}px;
    }

    .ai-product-row-name-{{ ai_gen_id }} {
      font-size: {{ block.settings.name_font_size_mobile }}px;
    }

    .ai-product-row-price-{{ ai_gen_id }} {
      font-size: {{ block.settings.price_font_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-product-row-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-row-wrapper-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank %}
      <h2 class="ai-product-row-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
    {% endif %}

    <div class="ai-product-row-container-{{ ai_gen_id }}">
      <ul class="ai-product-row-list-{{ ai_gen_id }}">
        {% for i in (1..12) %}
          {% assign product_key = 'product_' | append: i %}
          {% assign product = block.settings[product_key] %}
          
          {% if product != blank %}
            <li class="ai-product-row-item-{{ ai_gen_id }}">
              <a href="{{ product.url }}" class="ai-product-row-link-{{ ai_gen_id }}">
                <div class="ai-product-row-image-wrapper-{{ ai_gen_id }}">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      class="ai-product-row-image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="600"
                      height="600"
                    >
                  {% else %}
                    <div class="ai-product-row-image-placeholder-{{ ai_gen_id }}">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
                <div class="ai-product-row-info-{{ ai_gen_id }}">
                  <h3 class="ai-product-row-name-{{ ai_gen_id }}">{{ product.title }}</h3>
                  <p class="ai-product-row-price-{{ ai_gen_id }}">{{ product.price | money }}</p>
                </div>
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  </div>
</div>

